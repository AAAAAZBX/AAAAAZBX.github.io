# 复制为 .env 并填写；Astro 中 PUBLIC_ 会注入到构建与浏览器端。

PUBLIC_WALINE_SERVER_URL=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# 可选：高德开放平台「Web 服务」Key。填写后，国内公网 IP 的省/市/地图点优先用高德 v3，否则仍用 ipapi。
# 申请：https://console.amap.com/ → 应用管理 → 我的应用 → 添加「Web 服务」Key
# 安全：在 高德控制台 为该 Key 设置「域名白名单」，例如 https://你的github用户名.github.io 与 http://localhost:4321
PUBLIC_AMAP_WEB_KEY=
