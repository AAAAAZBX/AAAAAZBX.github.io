---
import Layout from "../layouts/Layout.astro";
import { getMergedPosts } from "../lib/content-posts";
import {
  buildCategoryPathTree,
  buildContentFolderDisplayMap,
} from "../lib/category-tree";
import CategoryPathTree from "../components/CategoryPathTree.astro";

const allPosts = await getMergedPosts();
const folderDisplayMap = buildContentFolderDisplayMap();

const researchPosts = allPosts.filter((p) => p.collection === "research");
const algorithmPosts = allPosts.filter((p) => p.collection === "algorithms");
const travelPosts = allPosts.filter((p) => p.collection === "travel");
const learningPosts = allPosts.filter((p) => p.collection === "learning");

const treeOpts = { folderDisplayMap } as const;

const researchTree = buildCategoryPathTree(researchPosts, {
  ...treeOpts,
  collection: "research",
});
const algorithmTree = buildCategoryPathTree(algorithmPosts, {
  ...treeOpts,
  collection: "algorithms",
});
const travelTree = buildCategoryPathTree(travelPosts, {
  ...treeOpts,
  collection: "travel",
});
const learningTree = buildCategoryPathTree(learningPosts, {
  ...treeOpts,
  collection: "learning",
});

const heroImageUrl = `${import.meta.env.BASE_URL}site-profile.png`;
const bannerTypedText = "Categories";
---

<Layout title="Categories — Boxuan Zhang" overlayNav>
  <div class="fluid-index-header-inner fluid-header-inner-compact">
    <div
      id="banner"
      class="fluid-banner"
      style={{
        backgroundImage: `url(${JSON.stringify(heroImageUrl)})`,
      }}
    >
      <div class="fluid-banner-inner">
        <div class="fluid-banner-mask">
          <div class="fluid-banner-text">
            <h1 class="fluid-banner-title" lang="en" aria-label={bannerTypedText}>
              <span id="fluid-hero-typed" data-typed-text={bannerTypedText}></span>
            </h1>
          </div>
          <a
            href="#fluid-board"
            class="fluid-scroll-down"
            aria-label="Scroll to categories"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <main id="fluid-board" class="fluid-index-main fluid-board-page fluid-categories-main">
    <div class="fluid-container fluid-nopadding-x-md">
      <div id="board" class="fluid-board-surface">
        <div class="fluid-container">
          <div class="fluid-row">
            <div class="fluid-col-12 fluid-col-md-10 fluid-m-auto">
              <ul class="fluid-category-list category-list">
                <li class="fluid-category-section cat-section">
                  <div class="category row nomargin-x">
                    <a
                      class="category-item list-group-item category-item-action col-10 col-md-11 col-xm-11 collapsed"
                      id="heading-collapse-section-research"
                      role="tab"
                      data-toggle="collapse"
                      href="#collapse-section-research"
                      aria-expanded="false"
                      aria-controls="collapse-section-research"
                    >
                      Research
                      <span class="list-group-count"></span>
                      <i class="iconfont icon-arrowright" aria-hidden="true"></i>
                    </a>
                    <span class="category-count col-2 col-md-1 col-xm-1">
                      <i class="iconfont icon-articles" aria-hidden="true"></i>
                      <span>{researchPosts.length}</span>
                    </span>
                    <div
                      class="category-collapse collapse w-100"
                      id="collapse-section-research"
                      role="tabpanel"
                      aria-labelledby="heading-collapse-section-research"
                    >
                      {researchPosts.length === 0 ? (
                        <p class="cat-panel-empty">暂无文章。</p>
                      ) : (
                        <CategoryPathTree node={researchTree} />
                      )}
                    </div>
                  </div>
                </li>

                <li class="fluid-category-section cat-section">
                  <div class="category row nomargin-x">
                    <a
                      class="category-item list-group-item category-item-action col-10 col-md-11 col-xm-11 collapsed"
                      id="heading-collapse-section-learning"
                      role="tab"
                      data-toggle="collapse"
                      href="#collapse-section-learning"
                      aria-expanded="false"
                      aria-controls="collapse-section-learning"
                    >
                      Technology
                      <span class="list-group-count"></span>
                      <i class="iconfont icon-arrowright" aria-hidden="true"></i>
                    </a>
                    <span class="category-count col-2 col-md-1 col-xm-1">
                      <i class="iconfont icon-articles" aria-hidden="true"></i>
                      <span>{learningPosts.length}</span>
                    </span>
                    <div
                      class="category-collapse collapse w-100"
                      id="collapse-section-learning"
                      role="tabpanel"
                      aria-labelledby="heading-collapse-section-learning"
                    >
                      {learningPosts.length === 0 ? (
                        <p class="cat-panel-empty">暂无文章。</p>
                      ) : (
                        <CategoryPathTree node={learningTree} />
                      )}
                    </div>
                  </div>
                </li>

                <li class="fluid-category-section cat-section">
                  <div class="category row nomargin-x">
                    <a
                      class="category-item list-group-item category-item-action col-10 col-md-11 col-xm-11 collapsed"
                      id="heading-collapse-section-algorithms"
                      role="tab"
                      data-toggle="collapse"
                      href="#collapse-section-algorithms"
                      aria-expanded="false"
                      aria-controls="collapse-section-algorithms"
                    >
                      Competitive Programming
                      <span class="list-group-count"></span>
                      <i class="iconfont icon-arrowright" aria-hidden="true"></i>
                    </a>
                    <span class="category-count col-2 col-md-1 col-xm-1">
                      <i class="iconfont icon-articles" aria-hidden="true"></i>
                      <span>{algorithmPosts.length}</span>
                    </span>
                    <div
                      class="category-collapse collapse w-100"
                      id="collapse-section-algorithms"
                      role="tabpanel"
                      aria-labelledby="heading-collapse-section-algorithms"
                    >
                      {algorithmPosts.length === 0 ? (
                        <p class="cat-panel-empty">暂无文章。</p>
                      ) : (
                        <CategoryPathTree node={algorithmTree} />
                      )}
                    </div>
                  </div>
                </li>

                <li class="fluid-category-section cat-section">
                  <div class="category row nomargin-x">
                    <a
                      class="category-item list-group-item category-item-action col-10 col-md-11 col-xm-11 collapsed"
                      id="heading-collapse-section-travel"
                      role="tab"
                      data-toggle="collapse"
                      href="#collapse-section-travel"
                      aria-expanded="false"
                      aria-controls="collapse-section-travel"
                    >
                      Daily Life
                      <span class="list-group-count"></span>
                      <i class="iconfont icon-arrowright" aria-hidden="true"></i>
                    </a>
                    <span class="category-count col-2 col-md-1 col-xm-1">
                      <i class="iconfont icon-articles" aria-hidden="true"></i>
                      <span>{travelPosts.length}</span>
                    </span>
                    <div
                      class="category-collapse collapse w-100"
                      id="collapse-section-travel"
                      role="tabpanel"
                      aria-labelledby="heading-collapse-section-travel"
                    >
                      {travelPosts.length === 0 ? (
                        <p class="cat-panel-empty">暂无文章。</p>
                      ) : (
                        <CategoryPathTree node={travelTree} />
                      )}
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline src="https://lib.baomitu.com/typed.js/2.0.12/typed.min.js"></script>
  <script is:inline>
    (function () {
      function fluidHeroTyping() {
        if (typeof window.Typed === "undefined") return;
        var el = document.getElementById("fluid-hero-typed");
        if (!el) return;
        var text = el.getAttribute("data-typed-text");
        if (!text) return;
        el.textContent = "";
        new window.Typed("#fluid-hero-typed", {
          strings: ["  ", text],
          typeSpeed: 50,
          cursorChar: "_",
          loop: false,
          showCursor: true,
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fluidHeroTyping);
      } else {
        fluidHeroTyping();
      }
    })();
  </script>

  <!-- Bootstrap 4 风格 collapse：height 过渡，与 Fluid categories 一致 -->
  <script is:inline>
    (function () {
      var board = document.getElementById("fluid-board");
      if (!board) return;

      function transitionComplete(el, done) {
        var ms = 400;
        var t = setTimeout(done, ms);
        el.addEventListener(
          "transitionend",
          function te(ev) {
            if (ev.target !== el || ev.propertyName !== "height") return;
            clearTimeout(t);
            el.removeEventListener("transitionend", te);
            done();
          },
          false,
        );
      }

      function showCollapse(el) {
        el.classList.remove("collapse");
        el.classList.add("collapsing");
        el.style.height = "0px";
        el.offsetHeight;
        var h = el.scrollHeight;
        el.style.height = h + "px";
        transitionComplete(el, function () {
          el.classList.remove("collapsing");
          el.classList.add("collapse", "show");
          el.style.removeProperty("height");
        });
      }

      function hideCollapse(el) {
        var rectH = el.getBoundingClientRect().height;
        el.style.height = (rectH || el.scrollHeight) + "px";
        el.offsetHeight;
        el.classList.remove("collapse", "show");
        el.classList.add("collapsing");
        el.style.height = "0px";
        transitionComplete(el, function () {
          el.classList.remove("collapsing");
          el.classList.add("collapse");
          el.style.removeProperty("height");
        });
      }

      board.addEventListener(
        "click",
        function (e) {
          var t = e.target && e.target.closest("[data-toggle='collapse']");
          if (!t || !board.contains(t)) return;
          var href = t.getAttribute("href");
          if (!href || href.charAt(0) !== "#") return;
          e.preventDefault();
          var target = document.querySelector(href);
          if (!target || !board.contains(target)) return;
          var open = target.classList.contains("show");
          if (open) {
            hideCollapse(target);
            t.classList.add("collapsed");
            t.setAttribute("aria-expanded", "false");
          } else {
            showCollapse(target);
            t.classList.remove("collapsed");
            t.setAttribute("aria-expanded", "true");
          }
        },
        false,
      );
    })();
  </script>

  <style>
    .cat-section {
      border-bottom: 1px solid var(--fluid-line-color);
    }

    .cat-section:first-child .category.row {
      border-top: 1px solid var(--fluid-line-color);
    }

    .cat-panel-empty {
      margin: 0;
      padding: 0.75rem 1.25rem;
      font-size: 1rem;
      line-height: 1.5;
      font-weight: 400;
      color: var(--fluid-sec-text-color);
    }
  </style>
</Layout>
