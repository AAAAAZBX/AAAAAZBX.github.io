---
import Layout from "../layouts/Layout.astro";
import AdminGate from "../components/AdminGate.astro";
import AnalyticsConsole from "../components/AnalyticsConsole.astro";
---

<Layout title="Analytics - Boxuan Zhang" overlayNav hideNav noindex lockPageDarkTheme>
  <AdminGate title="Visitor Portrait Analytics">
    <main class="analytics-main">
      <div class="analytics-topbar">
        <div>
          <h1 class="analytics-title">Visitor Portrait Analytics</h1>
          <p class="analytics-sub">IP portraits, profile names, location traces, paths, and traffic flow context</p>
        </div>
        <a class="analytics-back" href={`${import.meta.env.BASE_URL}statistics`.replace(/([^:]\/)\/+/g, "$1")}>
          Statistics
        </a>
      </div>
      <AnalyticsConsole />
    </main>
  </AdminGate>
</Layout>

<style>
  .analytics-main {
    min-height: 100vh;
    width: 100%;
    padding: 18px 16px 32px;
    background:
      radial-gradient(circle at 10% 12%, rgba(56, 189, 248, 0.14), transparent 36%),
      radial-gradient(circle at 92% 8%, rgba(167, 139, 250, 0.12), transparent 38%),
      linear-gradient(160deg, #0b1220 0%, #0f172a 48%, #101b30 100%);
    color: #d8e3f2;
    overflow-x: auto;
  }
  .analytics-topbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    max-width: 1280px;
    margin: 0 auto 1.25rem;
  }
  .analytics-title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: 0.02em;
  }
  .analytics-sub {
    margin: 0.35rem 0 0;
    font-size: 0.88rem;
    color: #94a3b8;
  }
  .analytics-back {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    font-size: 0.85rem;
    color: #7dd3fc;
    text-decoration: none;
    border: 1px solid rgba(125, 211, 252, 0.35);
    background: rgba(15, 23, 42, 0.45);
  }
  .analytics-back:hover {
    background: rgba(56, 189, 248, 0.12);
  }
</style>
