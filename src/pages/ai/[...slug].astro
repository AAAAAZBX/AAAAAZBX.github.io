---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import FluidArticleBoard from "../../components/FluidArticleBoard.astro";
import FluidToc from "../../components/FluidToc.astro";
import WalineComment from "../../components/WalineComment.astro";
import FluidArticleHero from "../../components/FluidArticleHero.astro";
import {
  DEFAULT_SITE_AUTHOR,
  estimateReadingUnits,
  formatWordCountLabel,
  estimateReadMinutes,
  formatPostMetaDateLine,
  formatPostDatetimeAttr,
  resolveHeroImageUrl,
} from "../../lib/post-reading-stats";

export async function getStaticPaths() {
  const posts = await getCollection("ai");
  const paths: { params: { slug: string } }[] = [];

  posts.forEach((post) => {
    paths.push({ params: { slug: post.id } });
    const slugParts = post.id.split("/");
    const fileName = slugParts[slugParts.length - 1];
    if (fileName !== post.id) {
      paths.push({ params: { slug: fileName } });
    }
  });

  return paths;
}

const { slug } = Astro.params;
const slugArray = Array.isArray(slug) ? slug : [slug];
const slugString = slugArray.join("/");

const allPosts = await getCollection("ai");

let post = allPosts.find((p) => p.id === slugString);

if (!post) {
  const fileName = slugArray[slugArray.length - 1];
  post = allPosts.find((p) => {
    const postSlugParts = p.id.split("/");
    const postFileName = postSlugParts[postSlugParts.length - 1];
    return postFileName === fileName;
  });
}

if (!post) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const heroImageUrl = resolveHeroImageUrl(post.data.heroImage, base);
const units = estimateReadingUnits(post.body ?? "");
const wordsLabel = formatWordCountLabel(units);
const readMinutes = estimateReadMinutes(units);
const author = post.data.author?.trim() || DEFAULT_SITE_AUTHOR;
const dateLine = formatPostMetaDateLine(post.data.date);
const datetimeAttr = post.data.date ? formatPostDatetimeAttr(post.data.date) : "";
---

<Layout title={`${post.data.title} | AI`} overlayNav>
  <FluidArticleHero
    title={post.data.title}
    author={author}
    heroImageUrl={heroImageUrl}
    dateLine={dateLine}
    datetimeAttr={datetimeAttr}
    wordsLabel={wordsLabel}
    readMinutes={readMinutes}
  />
  <main id="article-main" class="fluid-article-page-main">
    <FluidArticleBoard seoTitle={post.data.title}>
      <FluidToc slot="toc" />
      <Content />
      <div slot="after" class="comment-section">
        <WalineComment />
      </div>
    </FluidArticleBoard>
  </main>
</Layout>
