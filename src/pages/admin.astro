---
import Layout from "../layouts/Layout.astro";
import AdminGate from "../components/AdminGate.astro";

const panels = [
  {
    title: "Statistics",
    href: "/statistics",
    tag: "Site + Visitor",
    desc: "内容统计、访客地图、城市分布、近期访问明细。",
    items: ["文章与浏览量", "访客地理分布", "Supabase/CountAPI 数据源"],
  },
  {
    title: "Analytics",
    href: "/analytics",
    tag: "IP Portrait",
    desc: "IP 画像、Profile Name 备注、访问路径、地区、ISP 与访问频率。",
    items: ["IP 自定义备注", "今天 UTC+8 流量线", "热门路径与画像表"],
  },
  {
    title: "AI",
    href: "/ai",
    tag: "Career Radar",
    desc: "大模型算法、RAG、Agent、评测、AI Infra 和项目路线。",
    items: ["LLM 知识体系", "RAG/Agent 项目", "中文+英文资料"],
  },
  {
    title: "FinTech",
    href: "/fintech",
    tag: "Industry Radar",
    desc: "金融科技、风控、支付、监管科技、AI in Finance 的学习路线。",
    items: ["金融业务地图", "风控/反欺诈", "监管与合规"],
  },
  {
    title: "Quant",
    href: "/quant",
    tag: "Research Radar",
    desc: "量化研究、因子、回测、组合优化、风险归因和交易工程。",
    items: ["多因子研究", "回测系统", "组合优化"],
  },
];
---

<Layout title="Admin - Boxuan Zhang" overlayNav hideNav noindex lockPageDarkTheme>
  <AdminGate title="Admin Dashboard">
    <main class="admin-main">
      <section class="admin-shell">
        <div class="admin-hero">
          <div>
            <p class="admin-kicker">Private Control Center</p>
            <h1>Admin Dashboard</h1>
            <p>
              汇总站点统计、访问画像、AI / FinTech / Quant 三条职业与行业追踪路线。进入任意子页面仍会复用同一个本地会话解锁状态。
            </p>
          </div>
          <div class="admin-hero__metric">
            <span>Private Routes</span>
            <strong>{panels.length}</strong>
            <small>Statistics / Analytics / AI / FinTech / Quant</small>
          </div>
        </div>

        <div class="admin-grid">
          {panels.map((panel) => (
            <a class="admin-card" href={panel.href}>
              <span>{panel.tag}</span>
              <h2>{panel.title}</h2>
              <p>{panel.desc}</p>
              <ul>
                {panel.items.map((item) => <li>{item}</li>)}
              </ul>
            </a>
          ))}
        </div>
      </section>
    </main>
  </AdminGate>
</Layout>

<style>
  .admin-main {
    min-height: 100vh;
    width: 100%;
    padding: 18px 16px 36px;
    background:
      radial-gradient(circle at 10% 12%, rgba(56, 189, 248, 0.16), transparent 36%),
      radial-gradient(circle at 86% 8%, rgba(244, 114, 182, 0.12), transparent 34%),
      linear-gradient(160deg, #0b1220 0%, #0f172a 48%, #101b30 100%);
    color: #d8e3f2;
  }
  .admin-shell {
    max-width: 1280px;
    margin: 0 auto;
  }
  .admin-hero,
  .admin-card {
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: rgba(15, 23, 42, 0.62);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.18);
  }
  .admin-hero {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) 220px;
    gap: 1rem;
    border-radius: 22px;
    padding: 1.35rem;
    margin-bottom: 1rem;
    background:
      linear-gradient(135deg, rgba(14, 165, 233, 0.2), transparent 38%),
      linear-gradient(155deg, rgba(15, 23, 42, 0.78), rgba(8, 13, 24, 0.82));
  }
  .admin-kicker {
    margin: 0 0 0.35rem;
    color: #38bdf8;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 800;
  }
  .admin-hero h1 {
    margin: 0;
    color: #f8fbff;
    font-size: clamp(1.7rem, 3vw, 2.7rem);
  }
  .admin-hero p,
  .admin-card p,
  .admin-card li,
  .admin-hero__metric small {
    color: #94a3b8;
    line-height: 1.6;
  }
  .admin-hero__metric {
    display: grid;
    align-content: center;
    justify-items: end;
    border-radius: 18px;
    padding: 1rem;
    background: rgba(2, 6, 23, 0.48);
  }
  .admin-hero__metric span,
  .admin-card span {
    color: #94a3b8;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
  }
  .admin-hero__metric strong {
    color: #f8fafc;
    font-size: 3rem;
    line-height: 1;
  }
  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .admin-card {
    display: block;
    border-radius: 18px;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }
  .admin-card:hover {
    transform: translateY(-2px);
    border-color: rgba(56, 189, 248, 0.36);
    background: rgba(56, 189, 248, 0.08);
  }
  .admin-card h2 {
    margin: 0.35rem 0 0;
    color: #f8fafc;
    font-size: 1.25rem;
  }
  .admin-card ul {
    margin: 0.65rem 0 0;
    padding-left: 1.1rem;
  }
  @media (max-width: 760px) {
    .admin-hero {
      grid-template-columns: 1fr;
    }
    .admin-hero__metric {
      justify-items: start;
    }
  }
</style>
