---
import Layout from "../layouts/Layout.astro";
import AdminGate from "../components/AdminGate.astro";
import SiteStatisticsSection from "../components/SiteStatisticsSection.astro";
import VisitorInsightsSection from "../components/VisitorInsightsSection.astro";
import AnalyticsConsole from "../components/AnalyticsConsole.astro";
import { getMergedPosts } from "../lib/content-posts";
import { countapiGetUrl, getCountapiNamespace, COUNTAPI_KEYS } from "../lib/site-stats";
import { isVisitorLogConfigured } from "../lib/visitor-env";
import {
  buildCollectionPieStats,
  buildPerArticleViewRows,
  calculateWordCount,
} from "../lib/statistics-build";

const allPosts = await getMergedPosts();
const countNs = getCountapiNamespace();
const { totalPosts, pieItems } = buildCollectionPieStats(allPosts);
const perArticleViewRows = buildPerArticleViewRows(allPosts, countNs);
const countStatsGetUrls = {
  site: countapiGetUrl(countNs, COUNTAPI_KEYS.sitePageViews),
};
const totalWordCount = allPosts.reduce((sum, p) => sum + calculateWordCount(p.body), 0);
const lastPostDateIso: string | null = (() => {
  const times = allPosts
    .map((p) => (p.date ? new Date(p.date).getTime() : NaN))
    .filter((t) => !Number.isNaN(t));
  if (times.length === 0) return null;
  return new Date(Math.max(...times)).toISOString();
})();
const siteStartDate = "2025-12-03";
const useSupabaseArticleStats = isVisitorLogConfigured();
---

<Layout title="Admin - Boxuan Zhang" overlayNav hideNav noindex lockPageDarkTheme>
  <AdminGate title="Private Console">
    <main class="admin-main">
      <section class="admin-shell">
        <div class="admin-pager" aria-label="Console tabs">
          <button class="admin-pager__tab is-active" type="button" data-admin-tab="statistics">Statistics</button>
          <button class="admin-pager__tab" type="button" data-admin-tab="analytics">Analytics</button>
          <button class="admin-pager__tab" type="button" data-admin-tab="access">Access</button>
        </div>

        <section class="admin-page is-active" data-admin-page="statistics">
          <div class="stats-console__topbar">
            <div class="stats-console__title-wrap">
              <h2 class="stats-console__title">Statistics Console</h2>
              <p class="stats-console__subtitle">Landscape dashboard for content and visitor insights</p>
            </div>
            <div class="stats-console__meta">
              <span class="stats-console__pill">Posts {totalPosts}</span>
              <span class="stats-console__pill">Source {useSupabaseArticleStats ? "Supabase" : "CountAPI"}</span>
            </div>
          </div>
          <div class="stats-console__grid">
            <section class="stats-console__panel" aria-label="Core statistics">
              <SiteStatisticsSection
                totalPosts={totalPosts}
                pieItems={pieItems}
                perArticleViewRows={perArticleViewRows}
                countStatsGetUrls={countStatsGetUrls}
                totalWordCount={totalWordCount}
                lastPostDateIso={lastPostDateIso}
                siteStartDate={siteStartDate}
                articleViewsSource={useSupabaseArticleStats ? "supabase" : "countapi"}
              />
            </section>
            <aside class="stats-console__panel" aria-label="Visitor insights">
              <VisitorInsightsSection />
            </aside>
          </div>
        </section>

        <section class="admin-page" data-admin-page="analytics">
          <AnalyticsConsole />
        </section>

        <section class="admin-page" data-admin-page="access">
          <div class="access-panel">
            <div class="access-topbar">
              <div>
                <h2 class="access-title">Access Control</h2>
                <p class="access-subtitle">Manage article visibility — hidden posts are excluded from public pages.</p>
              </div>
              <div class="access-actions">
                <button class="access-btn access-btn--primary" id="access-save">Save visibility</button>
                <button class="access-btn access-btn--secondary" id="access-reload">Reload</button>
              </div>
            </div>
            <div class="access-summary">
              <div class="access-metric"><span>Total</span><strong id="access-total">0</strong></div>
              <div class="access-metric"><span>Public</span><strong id="access-public">0</strong></div>
              <div class="access-metric"><span>Hidden</span><strong id="access-hidden">0</strong></div>
            </div>
            <div class="access-toolbar">
              <input id="access-filter" type="search" placeholder="Search title, id, collection..." />
              <button class="access-btn access-btn--secondary" id="access-show-all">Show all</button>
              <button class="access-btn access-btn--secondary" id="access-hide-filtered">Hide filtered</button>
              <button class="access-btn access-btn--secondary" id="access-show-filtered">Show filtered</button>
              <span class="access-toast" id="access-toast"></span>
            </div>
            <div class="access-groups" id="access-rows"></div>
          </div>
        </section>
      </section>
    </main>
  </AdminGate>
</Layout>

<style is:global>
  .admin-main {
    min-height: 100vh;
    width: 100%;
    padding: 16px;
    background:
      radial-gradient(circle at 12% 8%, rgba(48, 169, 222, 0.15), transparent 34%),
      radial-gradient(circle at 88% 10%, rgba(50, 86, 150, 0.14), transparent 38%),
      linear-gradient(155deg, #0b1220 0%, #0f172a 45%, #101b30 100%);
    color: #d8e3f2;
    overflow-x: auto;
  }
  .admin-shell {
    max-width: 1760px;
    margin: 0 auto;
  }
  .admin-pager {
    display: flex;
    gap: 0.55rem;
    margin: 0 0 0.95rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }
  .admin-pager__tab {
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: rgba(15, 23, 42, 0.56);
    color: #cbd5e1;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .admin-pager__tab.is-active {
    border-color: rgba(56, 189, 248, 0.5);
    background: rgba(56, 189, 248, 0.16);
    color: #dff6ff;
  }
  .admin-page {
    display: none;
  }
  .admin-page.is-active {
    display: block;
  }

  .stats-console__topbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px 20px;
    padding: 4px 2px 8px;
  }
  .stats-console__title {
    margin: 0;
    color: #f1f6ff;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .stats-console__subtitle {
    margin: 4px 0 0;
    color: rgba(206, 221, 241, 0.76);
    font-size: 0.82rem;
  }
  .stats-console__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .stats-console__pill {
    color: #e0f2fe;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.9;
  }
  .stats-console__grid {
    display: grid;
    grid-template-columns: minmax(300px, 0.72fr) minmax(840px, 2.03fr);
    gap: 12px;
  }
  .stats-console__panel {
    min-height: 0;
    padding: 4px;
  }

  .access-panel { padding: 8px 0; }
  .access-topbar { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
  .access-title { margin: 0; color: #f1f6ff; font-size: 1.08rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; }
  .access-subtitle { margin: 4px 0 0; color: rgba(206, 221, 241, 0.76); font-size: 0.82rem; }
  .access-actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .access-btn { border-radius: 6px; padding: 8px 14px; font: inherit; font-size: 0.8rem; font-weight: 600; cursor: pointer; border: 1px solid; }
  .access-btn--primary { border-color: rgba(56, 189, 248, 0.5); background: rgba(56, 189, 248, 0.18); color: #38bdf8; }
  .access-btn--primary:hover { background: rgba(56, 189, 248, 0.28); }
  .access-btn--primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .access-btn--secondary { border-color: rgba(148, 163, 184, 0.24); background: rgba(15, 23, 42, 0.56); color: #cbd5e1; }
  .access-btn--secondary:hover { background: rgba(148, 163, 184, 0.18); }
  .access-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-bottom: 14px; }
  .access-metric { background: rgba(17, 24, 39, 0.7); border: 1px solid rgba(148, 163, 184, 0.16); border-radius: 8px; padding: 14px; }
  .access-metric span { display: block; color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .access-metric strong { display: block; margin-top: 4px; font-size: 1.4rem; color: #f1f6ff; }
  .access-toolbar { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-bottom: 14px; }
  .access-toolbar input[type="search"] { width: min(420px, 100%); padding: 8px 12px; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(148, 163, 184, 0.24); border-radius: 6px; color: #f1f6ff; font: inherit; font-size: 0.82rem; }
  .access-toolbar input[type="search"]::placeholder { color: #64748b; }
  .access-toast { color: #4ade80; font-size: 0.8rem; font-weight: 600; min-height: 20px; }
  .access-groups { display: flex; flex-direction: column; gap: 8px; }
  .access-group { background: rgba(17, 24, 39, 0.7); border: 1px solid rgba(148, 163, 184, 0.18); border-radius: 8px; overflow: hidden; }
  .access-group-summary { display: flex; align-items: center; gap: 10px; padding: 10px 14px; cursor: pointer; user-select: none; list-style: none; color: #e2e8f0; font-weight: 700; font-size: 0.85rem; }
  .access-group-summary::-webkit-details-marker { display: none; }
  .access-group-summary::marker { display: none; content: ""; }
  .access-group-arrow { color: #38bdf8; font-size: 0.6rem; transition: transform 0.25s ease; display: inline-block; }
  details[open] > .access-group-summary .access-group-arrow { transform: rotate(90deg); }
  .access-group-name { flex: 0 0 auto; }
  .access-group-meta { color: #64748b; font-size: 0.72rem; font-weight: 400; }
  .access-group-body { overflow: hidden; transition: max-height 0.3s ease; }
  .access-group-body-inner { padding: 0 14px 10px; }
  .access-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
  .access-table th, .access-table td { padding: 8px 10px; border-bottom: 1px solid rgba(148, 163, 184, 0.08); text-align: left; vertical-align: top; font-size: 0.82rem; }
  .access-table th { color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .access-table tr:last-child td { border-bottom: 0; }
  .access-th--title { width: 68%; } .access-th--visibility { width: 17%; } .access-th--file { width: 15%; }
  .access-title-text { font-weight: 700; color: #e2e8f0; overflow-wrap: anywhere; }
  .access-meta { margin-top: 2px; color: #64748b; font-size: 0.72rem; overflow-wrap: anywhere; }
  .access-switch { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; cursor: pointer; }
  .access-switch input[type="checkbox"] { accent-color: #38bdf8; }
  .access-status { display: inline-flex; align-items: center; border-radius: 999px; padding: 3px 8px; font-size: 0.72rem; font-weight: 700; }
  .access-status--public { background: #dcfce7; color: #166534; }
  .access-status--hidden { background: #fee2e2; color: #991b1b; }
  .access-notice { color: #64748b; font-size: 0.82rem; padding: 24px 12px; text-align: center; }

  @media (max-width: 1360px) {
    .stats-console__grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 900px) {
    /* reserved */
  }
</style>

<script>
  const VALID_TABS = ["statistics", "analytics", "access"];

  let accessPosts = [];
  let accessHidden = new Set();
  let accessQuery = "";

  function accessMatches(post) {
    if (!accessQuery) return true;
    const haystack = [post.title, post.id, post.date, post.collection].join(" ").toLowerCase();
    return haystack.includes(accessQuery.toLowerCase());
  }
  function accessVisiblePosts() { return accessPosts.filter(accessMatches); }

  function accessHiddenCount() {
    return accessPosts.reduce((total, post) => total + (accessHidden.has(post.id) ? 1 : 0), 0);
  }

  function accessUpdateSummary() {
    const t = document.getElementById("access-total"), p = document.getElementById("access-public"), h = document.getElementById("access-hidden");
    const hiddenCount = accessHiddenCount();
    if (t) t.textContent = accessPosts.length;
    if (h) h.textContent = hiddenCount;
    if (p) p.textContent = accessPosts.length - hiddenCount;
  }

  function accessEscapeHtml(v) { return String(v).replace(/[&<>"']/g, ch => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" }[ch])); }

  function accessRowHtml(p) {
    const isH = accessHidden.has(p.id);
    return `<tr><td><div class="access-title-text">${accessEscapeHtml(p.title)}</div><div class="access-meta">${accessEscapeHtml(p.id)}${p.date ? " · " + accessEscapeHtml(p.date) : ""}</div></td><td><label class="access-switch"><input type="checkbox" data-key="${accessEscapeHtml(p.id)}" ${isH ? "" : "checked"} /><span class="access-status ${isH ? "access-status--hidden" : "access-status--public"}">${isH ? "Hidden" : "Public"}</span></label></td><td><div class="access-meta">${accessEscapeHtml(p.id)}</div></td></tr>`;
  }

  function accessRender() {
    const container = document.getElementById("access-rows"); if (!container) return;
    accessUpdateSummary();
    const posts = accessVisiblePosts();
    if (!posts.length) { container.innerHTML = '<div class="access-notice">No matching posts.</div>'; return; }

    const groups = new Map();
    for (const p of posts) {
      const col = p.collection || "Other";
      if (!groups.has(col)) groups.set(col, []);
      groups.get(col).push(p);
    }

    let html = "";
    for (const [col, colPosts] of groups) {
      const hiddenCount = colPosts.filter(p => accessHidden.has(p.id)).length;
      html += `<details class="access-group" open><summary class="access-group-summary"><span class="access-group-arrow">▶</span><span class="access-group-name">${accessEscapeHtml(col)}</span><span class="access-group-meta">${colPosts.length} posts${hiddenCount ? ", " + hiddenCount + " hidden" : ""}</span></summary><div class="access-group-body"><div class="access-group-body-inner"><table class="access-table"><thead><tr><th class="access-th--title">Article</th><th class="access-th--visibility">Visibility</th><th class="access-th--file">ID</th></tr></thead><tbody>${colPosts.map(accessRowHtml).join("")}</tbody></table></div></div></details>`;
    }
    container.innerHTML = html;

    // Smooth toggle: intercept summary clicks, animate max-height manually
    container.querySelectorAll("details.access-group summary").forEach(summary => {
      summary.addEventListener("click", e => {
        e.preventDefault();
        const details = summary.closest("details");
        const body = details.querySelector(".access-group-body");
        if (!body) return;

        if (details.open) {
          // Close: lock height → animate to 0 → clean up
          body.style.maxHeight = body.scrollHeight + "px";
          body.offsetHeight; // force reflow
          body.style.maxHeight = "0px";
          const onDone = () => {
            details.open = false;
            body.style.maxHeight = "";
            body.removeEventListener("transitionend", onDone);
          };
          body.addEventListener("transitionend", onDone);
        } else {
          // Open: set max-height:0 → open details → animate to full height
          body.style.maxHeight = "0px";
          details.open = true;
          const h = body.scrollHeight;
          body.offsetHeight; // force reflow
          body.style.maxHeight = h + "px";
          const onDone = () => {
            body.style.maxHeight = "";
            body.removeEventListener("transitionend", onDone);
          };
          body.addEventListener("transitionend", onDone);
        }
      });
    });
  }

  async function accessLoad() {
    const toast = document.getElementById("access-toast");
    try { const r = await fetch("/api/posts", { cache: "no-store" }); const d = await r.json(); accessPosts = d.posts || []; accessHidden = new Set(d.hidden || []); accessRender(); if (toast) { toast.textContent = "Loaded"; setTimeout(() => { if (toast) toast.textContent = ""; }, 1200); } } catch (e) { if (toast) toast.textContent = "Load failed: " + e.message; }
  }

  async function accessSave() {
    const btn = document.getElementById("access-save"), toast = document.getElementById("access-toast");
    if (!btn) return; btn.disabled = true;
    try { const params = new URLSearchParams(); for (const id of accessHidden) params.append("hidden", id); const r = await fetch("/api/visibility?" + params.toString()); const d = await r.json(); if (!r.ok) throw new Error(d.reason || d.error || "Save failed"); if (toast) { toast.textContent = (d.synced !== false ? "Saved & synced." : "Saved locally.") + (d.rebuilt ? " Rebuild triggered." : ""); setTimeout(() => { if (toast) toast.textContent = ""; }, 2000); } } catch (e) { if (toast) toast.textContent = "Save failed: " + e.message; } finally { btn.disabled = false; }
  }

  function bindAccessPanel() {
    const container = document.getElementById("access-rows"); if (container && container.dataset.bound === "true") return; if (container) container.dataset.bound = "true";
    container?.addEventListener("change", e => { const i = e.target.closest("input[data-key]"); if (!i) return; if (i.checked) accessHidden.delete(i.dataset.key); else accessHidden.add(i.dataset.key); accessRender(); });
    document.getElementById("access-filter")?.addEventListener("input", e => { accessQuery = e.target.value.trim(); accessRender(); });
    document.getElementById("access-reload")?.addEventListener("click", accessLoad);
    document.getElementById("access-save")?.addEventListener("click", accessSave);
    document.getElementById("access-show-all")?.addEventListener("click", () => { const f = document.getElementById("access-filter"); if (f) f.value = ""; accessQuery = ""; accessRender(); });
    document.getElementById("access-hide-filtered")?.addEventListener("click", () => { for (const p of accessVisiblePosts()) accessHidden.add(p.id); accessRender(); });
    document.getElementById("access-show-filtered")?.addEventListener("click", () => { for (const p of accessVisiblePosts()) accessHidden.delete(p.id); accessRender(); });
    accessLoad().catch(e => { const t = document.getElementById("access-toast"); if (t) t.textContent = "Failed to load: " + e.message; });
  }

  (() => {
    const tabs = Array.from(document.querySelectorAll("[data-admin-tab]"));
    const pages = Array.from(document.querySelectorAll("[data-admin-page]"));
    if (!tabs.length || !pages.length) return;

    const activate = (id, { replace = false } = {}) => {
      const nextId = VALID_TABS.includes(id) ? id : "statistics";
      tabs.forEach((tab) => tab.classList.toggle("is-active", tab.dataset.adminTab === nextId));
      pages.forEach((page) => page.classList.toggle("is-active", page.dataset.adminPage === nextId));

      const url = new URL(window.location.href);
      url.searchParams.set("tab", nextId);
      const method = replace ? "replaceState" : "pushState";
      window.history[method]({}, "", url);

      if (nextId === "access") bindAccessPanel();
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const id = tab.dataset.adminTab;
        if (!id) return;
        activate(id);
      });
    });

    const initial = new URL(window.location.href).searchParams.get("tab") ?? "statistics";
    activate(initial, { replace: true });

    window.addEventListener("popstate", () => {
      const current = new URL(window.location.href).searchParams.get("tab") ?? "statistics";
      activate(current, { replace: true });
    });
  })();
</script>
