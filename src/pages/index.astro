---
import Layout from "../layouts/Layout.astro";
import {
  getMergedPosts,
  formatDateIso,
} from "../lib/content-posts";
import { buildContentFolderDisplayMap } from "../lib/category-tree";

const siteTitle = "Boxuan Zhang";

/** 首屏打字机文案（与 Hexo Fluid + Typed.js 一致，见 lynx-li.github.io） */
const heroTypedText = "等博主做完毕业设计，一定猛猛更新！";

/** public/ 下资源；带 BASE_URL 以支持 GitHub Pages 子路径部署 */
const heroImageUrl = `${import.meta.env.BASE_URL}site-profile.png`;
const folderDisplayMap = buildContentFolderDisplayMap();

function stripMd(text: string): string {
  return text
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]+`/g, " ")
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, "$1")
    .replace(/!\[([^\]]*)\]\([^\)]+\)/g, "")
    .replace(/^#+\s+/gm, "")
    .replace(/\*\*([^\*]+)\*\*/g, "$1")
    .replace(/\*([^\*]+)\*/g, "$1")
    .replace(/~~([^~]+)~~/g, "$1")
    .replace(/^>\s+/gm, "")
    .replace(/^[\*\-\+]\s+/gm, "")
    .replace(/^\d+\.\s+/gm, "")
    .replace(/<[^>]+>/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function excerptFromPost(body: string | undefined, maxLen = 260): string {
  const safeBody = typeof body === "string" ? body : "";
  const noCode = safeBody.replace(/```[\s\S]*?```/g, " ");
  const singleLine = stripMd(noCode.replace(/\r?\n+/g, " "));
  if (singleLine.length <= maxLen) return singleLine;
  return `${singleLine.slice(0, maxLen)}…`;
}

function normSeg(seg: string): string {
  return seg.trim().replace(/\s/g, "-").replace(/[A-Z]/g, (c) => c.toLowerCase());
}

function archiveHierarchyLabel(collection: string, slug: string): string {
  const dirs = slug.split("/").filter(Boolean).slice(0, -1);
  const displayDirs = dirs.map((seg, idx) => {
    const pathKey = `${collection}/${dirs.slice(0, idx + 1).map(normSeg).join("/")}`;
    return folderDisplayMap.get(pathKey) ?? seg;
  });
  return [collection, ...displayDirs].join(" > ");
}

const merged = await getMergedPosts();
const recentPosts = merged.slice(0, 24);
---

<Layout title={`${siteTitle} — Home`} overlayNav>
  <div class="fluid-index-header-inner">
    <div id="banner" class="fluid-banner fluid-banner-photo-mode">
      <div class="fluid-banner-bg" aria-hidden="true">
        <img
          class="fluid-banner-photo"
          src={heroImageUrl}
          alt=""
          width="1440"
          height="1080"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="fluid-banner-inner">
        <div class="fluid-banner-mask">
          <div class="fluid-banner-text">
            <h1 class="fluid-banner-title" lang="zh-CN" aria-label={heroTypedText}>
              <span id="fluid-hero-typed" data-typed-text={heroTypedText}></span>
            </h1>
          </div>
          <a
            href="#fluid-board"
            class="fluid-scroll-down"
            aria-label="Scroll to recent posts"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <main id="fluid-board" class="fluid-index-main fluid-board-page">
    <div class="fluid-container fluid-nopadding-x-md">
      <div id="board" class="fluid-board-surface fluid-board-home">
        <div class="fluid-container">
          <div class="fluid-row">
            <div class="fluid-col-12 fluid-col-md-10 fluid-m-auto">
              <div class="home-feed">
                <ul class="home-post-list">
                  {recentPosts.map((item) => (
                    <li class="home-post-item index-card-mimic">
                      <a class="home-post-link" href={item.href}>
                        <span class="home-post-title">{item.title}</span>
                      </a>
                      {item.description?.trim() && (
                        <p class="home-post-subtitle">{item.description.trim()}</p>
                      )}
                      <p class="home-post-excerpt">{excerptFromPost(item.body)}</p>
                      <div class="home-post-meta">
                        <span class="home-post-meta-item">
                          <i class="iconfont icon-date" aria-hidden="true"></i>
                          <time class="home-post-date" datetime={item.date ?? ""}>
                            {formatDateIso(item.date)}
                          </time>
                        </span>
                        <span class="home-post-meta-item">
                          <i class="iconfont icon-category-fill" aria-hidden="true"></i>
                          <span class="home-post-cat">
                            {archiveHierarchyLabel(item.collection, item.slug)}
                          </span>
                        </span>
                        {item.tags.length > 0 && (
                          <span class="home-post-meta-item">
                            <i class="iconfont icon-tags-fill" aria-hidden="true"></i>
                            <span class="home-post-tags">
                              {item.tags.map((tag) => `#${tag}`).join("  ")}
                            </span>
                          </span>
                        )}
                      </div>
                    </li>
                  ))}
                </ul>

                {recentPosts.length === 0 && <p class="home-empty">No posts yet.</p>}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline src="https://lib.baomitu.com/typed.js/2.0.12/typed.min.js"></script>
  <script is:inline>
    (function () {
      function fluidHeroTyping() {
        if (typeof window.Typed === "undefined") return;
        var el = document.getElementById("fluid-hero-typed");
        if (!el) return;
        var text = el.getAttribute("data-typed-text");
        if (!text) return;
        el.textContent = "";
        /* 对齐 public/lynx-li.github.io/js/plugins.js typing：strings 先占位再正文 */
        new window.Typed("#fluid-hero-typed", {
          strings: ["  ", text],
          typeSpeed: 50,
          cursorChar: "_",
          loop: false,
          showCursor: true,
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fluidHeroTyping);
      } else {
        fluidHeroTyping();
      }

      function fluidHeroParallax() {
        var hero = document.querySelector(".fluid-index-header-inner");
        var bg = document.querySelector(".fluid-banner.fluid-banner-photo-mode .fluid-banner-bg");
        if (!hero || !bg) return;

        var ticking = false;
        function update() {
          var top = window.pageYOffset || document.documentElement.scrollTop || 0;
          var heroH = hero.clientHeight || 1;
          var progress = Math.min(Math.max(top / heroH, 0), 1);
          var y = Math.round(top * 0.28);
          var scale = (1 + progress * 0.04).toFixed(3);
          bg.style.transform = "translate3d(0," + y + "px,0) scale(" + scale + ")";
          ticking = false;
        }

        function requestUpdate() {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        }

        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
        update();
      }

      function fluidBoardLift() {
        var hero = document.querySelector(".fluid-index-header-inner");
        var board = document.querySelector("#board.fluid-board-home");
        if (!hero || !board) return;

        var ticking = false;
        function update() {
          var top = window.pageYOffset || document.documentElement.scrollTop || 0;
          var heroH = hero.clientHeight || 1;
          var progress = Math.min(Math.max(top / (heroH * 0.9), 0), 1);
          var lift = Math.round(progress * 76);
          board.style.transform = "translate3d(0," + (-lift) + "px,0)";
          ticking = false;
        }

        function requestUpdate() {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        }

        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
        update();
      }

      fluidHeroParallax();
      fluidBoardLift();
    })();
  </script>
</Layout>
