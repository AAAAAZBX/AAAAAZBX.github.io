---
import Layout from "../layouts/Layout.astro";
import {
  getMergedPosts,
  formatDateIso,
  collectionLabels,
} from "../lib/content-posts";

const siteTitle = "Boxuan Zhang";

/** 首屏打字机文案（与 Hexo Fluid + Typed.js 一致，见 lynx-li.github.io） */
const heroTypedText = "等博主做完毕业设计，一定猛猛更新！";

/** public/ 下资源；带 BASE_URL 以支持 GitHub Pages 子路径部署 */
const heroImageUrl = `${import.meta.env.BASE_URL}site-profile.png`;

function stripMd(text: string): string {
  return text
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]+`/g, " ")
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, "$1")
    .replace(/!\[([^\]]*)\]\([^\)]+\)/g, "")
    .replace(/^#+\s+/gm, "")
    .replace(/\*\*([^\*]+)\*\*/g, "$1")
    .replace(/\*([^\*]+)\*/g, "$1")
    .replace(/~~([^~]+)~~/g, "$1")
    .replace(/^>\s+/gm, "")
    .replace(/^[\*\-\+]\s+/gm, "")
    .replace(/^\d+\.\s+/gm, "")
    .replace(/<[^>]+>/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function excerptFromPost(description: string | undefined, body: string, maxLen = 220): string {
  if (description?.trim()) return description.trim();
  const plain = stripMd(body);
  if (plain.length <= maxLen) return plain;
  return `${plain.slice(0, maxLen)}…`;
}

const merged = await getMergedPosts();
const recentPosts = merged.slice(0, 24);
---

<Layout title={`${siteTitle} — Home`} overlayNav>
  <!-- 对齐 Hexo Fluid：header-inner 100vh + #banner 铺满 + fixed navbar 叠在图上 -->
  <div class="fluid-index-header-inner">
    <div id="banner" class="fluid-banner fluid-banner-photo-mode">
      <div class="fluid-banner-bg" aria-hidden="true">
        <img
          class="fluid-banner-photo"
          src={heroImageUrl}
          alt=""
          width="1440"
          height="1080"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="fluid-banner-inner">
        <div class="fluid-banner-mask">
          <div class="fluid-banner-text">
            <h1 class="fluid-banner-title" lang="zh-CN" aria-label={heroTypedText}>
              <span id="fluid-hero-typed" data-typed-text={heroTypedText}></span>
            </h1>
          </div>
          <a
            href="#fluid-board"
            class="fluid-scroll-down"
            aria-label="Scroll to recent posts"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6"></path>
            </svg>
            </a>
          </div>
              </div>
            </div>
          </div>

  <!-- 与 public/lynx-li.github.io/index.html 一致：main > .container.nopadding-x-md > #board > .container > .row > .col -->
  <main id="fluid-board" class="fluid-index-main fluid-board-page">
    <div class="fluid-container fluid-nopadding-x-md">
      <div id="board" class="fluid-board-surface fluid-board-home">
        <div class="fluid-container">
          <div class="fluid-row">
            <div class="fluid-col-12 fluid-col-md-10 fluid-m-auto">
              <div class="home-feed">
                <h2 class="home-feed-title">Recent Posts</h2>
                <p class="home-feed-desc">Latest updates from all categories.</p>

                <ul class="home-post-list">
                  {recentPosts.map((item) => (
                    <li class="home-post-item index-card-mimic">
                      <a class="home-post-link" href={item.href}>
                        <span class="home-post-title">{item.title}</span>
                      </a>
                      <p class="home-post-excerpt">{excerptFromPost(item.description, item.body)}</p>
                      <div class="home-post-meta">
                        <time class="home-post-date" datetime={item.date ?? ""}>{formatDateIso(item.date)}</time>
                        <span class="home-post-sep" aria-hidden="true">·</span>
                        <span class="home-post-cat">{collectionLabels[item.collection].en}</span>
            </div>
                    </li>
                  ))}
                </ul>

                {recentPosts.length === 0 && <p class="home-empty">No posts yet.</p>}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline src="https://lib.baomitu.com/typed.js/2.0.12/typed.min.js"></script>
  <script is:inline>
    (function () {
      function fluidHeroTyping() {
        if (typeof window.Typed === "undefined") return;
        var el = document.getElementById("fluid-hero-typed");
        if (!el) return;
        var text = el.getAttribute("data-typed-text");
        if (!text) return;
        el.textContent = "";
        /* 对齐 public/lynx-li.github.io/js/plugins.js typing：strings 先占位再正文 */
        new window.Typed("#fluid-hero-typed", {
          strings: ["  ", text],
          typeSpeed: 50,
          cursorChar: "_",
          loop: false,
          showCursor: true,
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fluidHeroTyping);
          } else {
        fluidHeroTyping();
      }
  })();
</script>
</Layout>
