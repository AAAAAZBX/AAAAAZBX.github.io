---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";
import FluidArticleBoard from "../../components/FluidArticleBoard.astro";
import FluidToc from "../../components/FluidToc.astro";
import WalineComment from "../../components/WalineComment.astro";
import FluidArticleHero from "../../components/FluidArticleHero.astro";
import {
  DEFAULT_SITE_AUTHOR,
  estimateReadingUnits,
  formatWordCountLabel,
  estimateReadMinutes,
  formatPostMetaDateLine,
  formatPostDatetimeAttr,
  resolveHeroImageUrl,
} from "../../lib/post-reading-stats";
import {
  getCollectionKeys,
  getCollectionLabel,
  type ColKey,
} from "../../lib/content-posts";
import { isPostVisible } from "../../lib/content-visibility";
import { countapiHitUrl, getCountapiNamespace, countapiArticleKey } from "../../lib/site-stats";
import { isVisitorLogConfigured } from "../../lib/visitor-env";

type RouteProps = {
  collection: ColKey;
  id: string;
};

export async function getStaticPaths() {
  const collectionKeys = getCollectionKeys();
  const buckets = await Promise.all(
    collectionKeys.map(async (collection) => {
      const posts = await getCollection(collection as never);
      return posts.filter((post) => isPostVisible(collection, post.id)).map((post) => ({
        params: { slug: `${collection}/${post.id}` },
        props: { collection, id: post.id } satisfies RouteProps,
      }));
    })
  );
  return buckets.flat();
}

const { collection, id } = Astro.props as RouteProps;
const post = await getEntry(collection, id);
if (!post || !isPostVisible(collection, id)) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const heroImageUrl = resolveHeroImageUrl(post.data.heroImage, base);
const units = estimateReadingUnits(post.body ?? "");
const wordsLabel = formatWordCountLabel(units);
const readMinutes = estimateReadMinutes(units);
const author = post.data.author?.trim() || DEFAULT_SITE_AUTHOR;
const dateLine = formatPostMetaDateLine(post.data.date);
const datetimeAttr = post.data.date ? formatPostDatetimeAttr(post.data.date) : "";
const sectionTitle = getCollectionLabel(collection).en;

const useSupabaseForArticleViews = isVisitorLogConfigured();
const countArticlePageHitUrl = useSupabaseForArticleViews
  ? null
  : countapiHitUrl(
      getCountapiNamespace(),
      countapiArticleKey(collection, id)
    );
---

<Layout title={`${post.data.title} | ${sectionTitle}`} overlayNav>
  <FluidArticleHero
    title={post.data.title}
    author={author}
    heroImageUrl={heroImageUrl}
    dateLine={dateLine}
    datetimeAttr={datetimeAttr}
    wordsLabel={wordsLabel}
    readMinutes={readMinutes}
  />
  <main id="article-main" class="fluid-article-page-main">
    <FluidArticleBoard seoTitle={post.data.title}>
      <FluidToc slot="toc" />
      <Content />
      <div
        slot="after"
        class="fluid-article-comment-wrap"
        style="margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--line-color);"
      >
        <WalineComment />
      </div>
    </FluidArticleBoard>
  </main>
  <script is:inline define:vars={{ countArticlePageHitUrl }}>
    (function () {
      if (!countArticlePageHitUrl) return;
      fetch(countArticlePageHitUrl, { mode: "cors", cache: "no-store" }).catch(
        function () {}
      );
    })();
  </script>
</Layout>
