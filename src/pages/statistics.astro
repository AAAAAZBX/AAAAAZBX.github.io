---
import Layout from "../layouts/Layout.astro";
import { getMergedPosts } from "../lib/content-posts";
import { countapiGetUrl, getCountapiNamespace, COUNTAPI_KEYS } from "../lib/site-stats";
import { isVisitorLogConfigured } from "../lib/visitor-env";
import {
  buildCollectionPieStats,
  buildPerArticleViewRows,
  calculateWordCount,
} from "../lib/statistics-build";
import SiteStatisticsSection from "../components/SiteStatisticsSection.astro";
import VisitorInsightsSection from "../components/VisitorInsightsSection.astro";

const allPosts = await getMergedPosts();
const countNs = getCountapiNamespace();
const { totalPosts, pieItems } = buildCollectionPieStats(allPosts);
const perArticleViewRows = buildPerArticleViewRows(allPosts, countNs);
const countStatsGetUrls = {
  site: countapiGetUrl(countNs, COUNTAPI_KEYS.sitePageViews),
};
/** 字数与最近更新在构建时算好，避免把全站正文塞进页面脚本导致内联 script 过大、浏览器不执行 */
const totalWordCount = allPosts.reduce(
  (sum, p) => sum + calculateWordCount(p.body),
  0
);
const lastPostDateIso: string | null = (() => {
  const times = allPosts
    .map((p) => (p.date ? new Date(p.date).getTime() : NaN))
    .filter((t) => !Number.isNaN(t));
  if (times.length === 0) return null;
  return new Date(Math.max(...times)).toISOString();
})();
/** 与 about 中 profile.siteStartDate 一致 */
const siteStartDate = "2025-12-03";
const useSupabaseArticleStats = isVisitorLogConfigured();

/* Tag cloud 暂时关闭（恢复时取消本段注释，并恢复下方被注释的 section / 脚本 / 样式）
const tagCounts = new Map<string, number>();
for (const p of allPosts) {
  for (const t of p.tags) {
    const k = t.trim();
    if (!k) continue;
    tagCounts.set(k, (tagCounts.get(k) || 0) + 1);
  }
}
const tagCloudPairs: [string, number][] = [...tagCounts.entries()].sort(
  (a, b) => b[1] - a[1]
);
*/

---

<Layout title="Statistics - Boxuan Zhang" overlayNav hideNav noindex>
  <main class="stats-console-main">
    <section class="stats-console">
      <div class="stats-console__topbar">
        <div class="stats-console__title-wrap">
          <h1 class="stats-console__title">Statistics Console</h1>
          <p class="stats-console__subtitle">Landscape dashboard for content and visitor insights</p>
        </div>
        <div class="stats-console__meta">
          <span class="stats-console__pill">Posts {totalPosts}</span>
          <span class="stats-console__pill">
            Source {useSupabaseArticleStats ? "Supabase" : "CountAPI"}
          </span>
        </div>
      </div>

      <div class="stats-console__grid">
        <section class="stats-console__panel stats-console__panel--main" aria-label="Core statistics">
          <SiteStatisticsSection
            totalPosts={totalPosts}
            pieItems={pieItems}
            perArticleViewRows={perArticleViewRows}
            countStatsGetUrls={countStatsGetUrls}
            totalWordCount={totalWordCount}
            lastPostDateIso={lastPostDateIso}
            siteStartDate={siteStartDate}
            articleViewsSource={useSupabaseArticleStats ? "supabase" : "countapi"}
          />
        </section>

        <aside class="stats-console__panel stats-console__panel--side" aria-label="Visitor insights">
          <VisitorInsightsSection />
        </aside>
      </div>
    </section>
  </main>

  <style is:global>
    .stats-console-main {
      min-height: 100vh;
      width: 100%;
      padding: 18px 16px 18px;
      background:
        radial-gradient(circle at 12% 8%, rgba(48, 169, 222, 0.18), transparent 34%),
        radial-gradient(circle at 88% 14%, rgba(50, 86, 150, 0.16), transparent 38%),
        linear-gradient(155deg, #0b1220 0%, #0f172a 45%, #101b30 100%);
      color: #d8e3f2;
      overflow-x: auto;
    }

    .stats-console {
      min-width: 1180px;
      max-width: 1760px;
      margin: 0 auto;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      gap: 14px;
    }

    .stats-console__topbar {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px 20px;
      border: none;
      border-radius: 0;
      background: transparent;
      padding: 6px 2px 2px;
      backdrop-filter: none;
    }

    .stats-console__title {
      margin: 0;
      color: #f1f6ff;
      font-size: 1.22rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .stats-console__subtitle {
      margin: 4px 0 0;
      color: rgba(206, 221, 241, 0.76);
      font-size: 0.82rem;
      letter-spacing: 0.03em;
    }

    .stats-console__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .stats-console__pill {
      border: none;
      color: #e0f2fe;
      background: transparent;
      border-radius: 0;
      padding: 0;
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      opacity: 0.82;
    }

    .stats-console__grid {
      display: grid;
      grid-template-columns: minmax(300px, 0.72fr) minmax(840px, 2.03fr);
      gap: 12px;
      min-height: calc(100vh - 200px);
    }

    .stats-console__panel {
      border: none;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      overflow: auto;
      min-height: 0;
      padding: 6px;
    }

    .stats-console__panel--main {
      scrollbar-gutter: stable;
    }

    .stats-console__panel--side {
      scrollbar-gutter: stable;
    }

    .stats-console-main .content-section.about-statistics-wrap.stat-scope {
      margin: 0;
      padding: 0;
      max-width: none;
      --text-primary: #ffffff;
      --text-secondary: #ffffff;
      --text-link: #ffffff;
      --text-link-hover: #ffffff;
    }

    /* 左列：上方小饼图，下方文章排行 */
    .stats-console-main .stat-scope .stat-dashboard {
      background: transparent;
      box-shadow: none;
      border: none;
    }

    .stats-console-main .stat-scope .stat-dashboard__rim {
      padding: 0;
      display: grid;
      grid-template-areas:
        "ring"
        "kpi"
        "bars";
      grid-template-rows: auto auto 1fr;
      gap: 12px;
      min-height: 0;
    }

    .stats-console-main .stat-scope .stat-dashboard__row--split {
      grid-area: ring;
      margin: 0;
    }

    .stats-console-main .stat-scope .stat-dashboard__kpi {
      grid-area: kpi;
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin: 0;
    }

    .stats-console-main .stat-scope .stat-kpi {
      display: flex;
      align-items: baseline;
      justify-content: flex-start;
      gap: 10px;
      padding: 0;
      border: none;
      background: transparent;
      border-radius: 0;
    }

    .stats-console-main .stat-scope .stat-kpi__label {
      flex: 0 0 138px;
      font-size: 0.66rem;
      margin: 0;
      letter-spacing: 0.08em;
      color: #ffffff;
      font-weight: 700;
    }

    .stats-console-main .stat-scope .stat-kpi__value {
      font-size: 0.96rem;
      color: #eff6ff;
      margin: 0;
      line-height: 1.3;
      font-weight: 400;
    }

    .stats-console-main .stat-scope .stat-kpi__value--text {
      font-size: 0.9rem;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .stats-console-main .stat-scope .stat-panel {
      margin: 0;
      border: none;
      background: transparent;
      border-radius: 0;
      box-shadow: none;
    }

    .stats-console-main .stat-scope .stat-panel--ring {
      padding: 10px 12px 12px;
    }

    .stats-console-main .stat-scope .stat-panel--ring .stat-panel__head {
      margin-bottom: 8px;
    }

    .stats-console-main .stat-scope .stat-panel--ring .stat-pie-wrap {
      justify-content: flex-start;
      align-items: center;
      gap: 10px 18px;
    }

    .stats-console-main .stat-scope .stat-panel--ring .stat-pie {
      width: 150px;
      height: 150px;
      margin: 0;
      flex: 0 0 150px;
    }

    .stats-console-main .stat-scope .stat-panel--ring .stat-pie__center-val {
      font-size: 1.45rem;
    }

    .stats-console-main .stat-scope .stat-panel--ring .stat-legend {
      max-width: calc(100% - 170px);
    }

    .stats-console-main .stat-scope .stat-panel--bars {
      grid-area: bars;
      display: flex;
      flex-direction: column;
      min-height: 0;
      padding: 12px;
    }

    .stats-console-main .stat-scope .stat-panel--bars .stat-panel__sub {
      margin-bottom: 10px;
    }

    .stats-console-main .stat-scope .stat-panel--bars .stat-bar-chart {
      flex: 0 0 auto;
      max-height: 300px;
      min-height: 0;
    }

    .stats-console-main .visitor-insights--embed {
      margin: 0;
      padding: 0;
      max-width: none;
    }

    /* 右列：上大地图，下两表并排 */
    .stats-console-main .visitor-insights--embed .visitor-insights__inner {
      display: grid;
      grid-template-columns: minmax(260px, 0.88fr) minmax(360px, 1.12fr);
      grid-template-areas:
        "title title"
        "map map"
        "city city"
        "raw raw";
      gap: 12px;
      min-height: 0;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__h1 {
      grid-area: title;
      margin-bottom: 0;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__h1 {
      color: #f1f6ff;
      margin-bottom: 0.65rem;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__lead {
      display: none;
    }

    .stats-console-main
      .visitor-insights--embed
      .visitor-insights__section[aria-label="World map"] {
      grid-area: map;
      margin-bottom: 0;
    }

    .stats-console-main
      .visitor-insights--embed
      .visitor-insights__section[aria-label="By city"] {
      grid-area: city;
      margin-bottom: 0;
      min-height: 0;
    }

    .stats-console-main
      .visitor-insights--embed
      .visitor-insights__section[aria-label="Raw visits"] {
      grid-area: raw;
      margin-bottom: 0;
      min-height: 0;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__map {
      height: min(56vh, 560px);
      min-height: 350px;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__lead,
    .stats-console-main .visitor-insights--embed .visitor-insights__muted {
      color: rgba(203, 215, 233, 0.82);
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__table-wrap,
    .stats-console-main .visitor-insights--embed .visitor-insights__map {
      border: none;
      border-radius: 0;
      background: rgba(6, 11, 20, 0.22);
      box-shadow: none;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__table-wrap {
      height: 300px;
      overflow: auto;
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__table--wide {
      min-width: 0;
    }

    .stats-console-main
      .visitor-insights--embed
      .visitor-insights__section[aria-label="By city"]
      .visitor-insights__table-wrap {
      height: 220px;
    }

    .stats-console-main
      .visitor-insights--embed
      .visitor-insights__section[aria-label="Raw visits"]
      .visitor-insights__table-wrap {
      height: clamp(340px, 46vh, 640px);
    }

    @media (max-width: 1280px) {
      .stats-console-main .visitor-insights--embed .visitor-insights__inner {
        grid-template-columns: 1fr;
        grid-template-areas:
          "title"
          "map"
          "city"
          "raw";
      }
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__table th,
    .stats-console-main .visitor-insights--embed .visitor-insights__table td {
      border-bottom-color: rgba(148, 163, 184, 0.2);
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__table th {
      background: rgba(11, 19, 34, 0.35);
    }

    .stats-console-main .visitor-insights--embed .visitor-insights__warn {
      border: none;
      border-radius: 0;
      background: rgba(14, 116, 144, 0.15);
    }

    @media (max-width: 1360px) {
      .stats-console {
        min-width: 1040px;
      }
      .stats-console__grid {
        grid-template-columns: minmax(280px, 0.83fr) minmax(710px, 1.75fr);
      }

      .stats-console-main .stat-scope .stat-kpi__label {
        flex-basis: 126px;
      }
    }
  </style>

</Layout>
