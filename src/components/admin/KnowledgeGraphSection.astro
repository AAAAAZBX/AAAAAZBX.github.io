---
import type { KnowledgeGraphPayload } from "../../lib/knowledge-graph";

interface Props {
  payload: KnowledgeGraphPayload;
  baseUrl: string;
}

const { payload, baseUrl } = Astro.props;
---

<section class="kg" aria-label="Knowledge graph">
  <div class="kg__topbar">
    <div>
      <h2 class="kg__title">Knowledge graph</h2>
      <p class="kg__subtitle">
        Obsidian-style link view: internal links, <code>[[wikilinks]]</code>, and filtered shared-tag bridges.
      </p>
    </div>
    <div class="kg__stats">
      <span class="kg__pill">{payload.nodes.length} notes</span>
      <span class="kg__pill">{payload.edges.length} links</span>
    </div>
  </div>

  <div class="kg__toolbar">
    <label class="kg__field">
      <span>Focus</span>
      <input type="search" id="kg-filter" placeholder="Title or collection…" autocomplete="off" />
    </label>
    <label class="kg__chk"><input type="checkbox" id="kg-kind-md" checked /> Markdown</label>
    <label class="kg__chk"><input type="checkbox" id="kg-kind-wiki" checked /> Wikilink</label>
    <label class="kg__chk"><input type="checkbox" id="kg-kind-tag" checked /> Shared tags</label>
    <button type="button" class="kg__btn" id="kg-reset">Reset layout</button>
    <span class="kg__hint">Drag nodes · Wheel zoom · Drag canvas pan</span>
  </div>

  <div class="kg__canvas-wrap">
    <canvas id="kg-canvas" class="kg__canvas" aria-label="Graph canvas"></canvas>
    <div class="kg__legend">
      <span><i class="kg__dot kg__dot--md"></i>Markdown / HTML link</span>
      <span><i class="kg__dot kg__dot--wiki"></i>Wikilink</span>
      <span><i class="kg__dot kg__dot--tag"></i>Shared tag</span>
      <span><i class="kg__dot kg__dot--hid"></i>Hidden post</span>
    </div>
  </div>
</section>

<style>
  .kg {
    padding: 8px 0 16px;
    color: #d8e3f2;
    max-width: 1860px;
    margin: 0 auto;
  }
  .kg__topbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .kg__title {
    margin: 0;
    color: #f1f6ff;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .kg__subtitle {
    margin: 4px 0 0;
    color: rgba(206, 221, 241, 0.76);
    font-size: 0.82rem;
    max-width: 640px;
    line-height: 1.45;
  }
  .kg__subtitle code {
    font-size: 0.78em;
    padding: 1px 6px;
    border-radius: 4px;
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }
  .kg__stats {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .kg__pill {
    color: #e0f2fe;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.9;
  }
  .kg__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    margin-bottom: 10px;
  }
  .kg__field {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    font-weight: 600;
  }
  .kg__field input[type="search"] {
    width: min(280px, 100%);
    padding: 8px 12px;
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 6px;
    color: #f1f6ff;
    font: inherit;
    font-size: 0.82rem;
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
  }
  .kg__chk {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: #cbd5e1;
    cursor: pointer;
    user-select: none;
  }
  .kg__chk input {
    accent-color: #38bdf8;
  }
  .kg__btn {
    border-radius: 6px;
    padding: 8px 14px;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid rgba(56, 189, 248, 0.45);
    background: rgba(56, 189, 248, 0.14);
    color: #38bdf8;
  }
  .kg__btn:hover {
    background: rgba(56, 189, 248, 0.24);
  }
  .kg__hint {
    font-size: 0.74rem;
    color: #64748b;
    flex: 1 1 160px;
    text-align: right;
  }
  .kg__canvas-wrap {
    position: relative;
    width: min(1760px, 100%);
    margin: 0 auto;
    border-radius: 10px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: radial-gradient(circle at 30% 18%, rgba(56, 189, 248, 0.06), transparent 42%),
      rgba(15, 23, 42, 0.55);
    overflow: hidden;
    isolation: isolate;
    min-height: min(80vh, 980px);
  }
  .kg__canvas {
    display: block;
    position: relative;
    z-index: 1;
    width: 100%;
    height: min(80vh, 980px);
    cursor: grab;
  }
  .kg__canvas.kg__canvas--drag {
    cursor: grabbing;
  }
  .kg__legend {
    position: absolute;
    z-index: 2;
    left: 12px;
    bottom: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    padding: 8px 12px;
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.82);
    border: 1px solid rgba(148, 163, 184, 0.14);
    font-size: 0.72rem;
    color: #94a3b8;
    pointer-events: none;
  }
  .kg__legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .kg__dot {
    width: 10px;
    height: 3px;
    border-radius: 2px;
    display: inline-block;
  }
  .kg__dot--md {
    background: rgba(56, 189, 248, 0.85);
  }
  .kg__dot--wiki {
    background: rgba(167, 139, 250, 0.9);
  }
  .kg__dot--tag {
    background: rgba(148, 163, 184, 0.65);
  }
  .kg__dot--hid {
    background: rgba(248, 113, 113, 0.55);
    height: 8px;
    width: 8px;
    border-radius: 50%;
    opacity: 0.85;
  }
</style>

<script define:vars={{ payload, baseUrl }}>
  (function () {
    const canvas = document.getElementById("kg-canvas");
    const filterInput = document.getElementById("kg-filter");
    const chkMd = document.getElementById("kg-kind-md");
    const chkWiki = document.getElementById("kg-kind-wiki");
    const chkTag = document.getElementById("kg-kind-tag");
    const btnReset = document.getElementById("kg-reset");
    if (!canvas || !(canvas instanceof HTMLCanvasElement)) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    /** @typedef {{ id: string; title: string; collection: string; tags: string[]; hidden: boolean; x: number; y: number; vx: number; vy: number; }} SimNode */
    /** @typedef {{ source: string; target: string; kinds: string[] }} PayloadEdge */

    /** @type {SimNode[]} */
    let nodes = [];
    /** @type {PayloadEdge[]} */
    let edges = payload.edges || [];

    // Per-collection node colours keyed to the site's dark-theme palette.
    const COLLECTION_COLORS = {
      "LLM":           "#38bdf8", // sky – primary accent
      "Algorithms":    "#2dd4bf", // teal – crisp, algorithmic
      "Math":          "#a78bfa", // violet – matches wikilink edges
      "Tools":         "#818cf8", // indigo – tool-like, cool
      "Life Moments":  "#f59e0b", // amber – warm pop against dark navy
    };
    const DEFAULT_NODE_COLOR = "#38bdf8";
    const DEFAULT_NODE_DIM = "rgba(56, 189, 248, 0.18)";
    const THEME_NODE_HIDDEN = "rgba(248, 113, 113, 0.50)";
    const THEME_TEXT = "rgba(226, 232, 240, 0.88)";
    const THEME_TEXT_DIM = "rgba(148, 163, 184, 0.32)";
    const THEME_TOOLTIP_BG = "rgba(15, 23, 42, 0.92)";
    const THEME_TOOLTIP_BD = "rgba(148, 163, 184, 0.20)";

    function nodeColor(collection) {
      return COLLECTION_COLORS[collection] || DEFAULT_NODE_COLOR;
    }
    function nodeColorDim(collection) {
      const hex = COLLECTION_COLORS[collection] || DEFAULT_NODE_COLOR;
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, 0.18)`;
    }

    function layoutCircle() {
      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(w, h) * 0.43;
      const adj = activeEdges();
      const { compId, comps } = buildComponents(adj);
      const anchors = computeComponentAnchors(comps);

      for (const n of nodes) {
        const c = compId.get(n.id) ?? 0;
        const a = anchors.get(c) ?? { x: cx, y: cy };
        const ang = Math.random() * Math.PI * 2;
        const rr = r * (0.55 + Math.random() * 0.35);
        n.x = a.x + Math.cos(ang) * rr;
        n.y = a.y + Math.sin(ang) * rr;
        n.vx = 0;
        n.vy = 0;
      }
    }

    function initNodes() {
      nodes = (payload.nodes || []).map((p) => ({
        id: p.id,
        title: p.title,
        collection: p.collection,
        tags: Array.from(
          new Map(
            (Array.isArray(p.tags) ? p.tags : [])
              .map((t) => String(t ?? "").trim().replace(/^#+/, "")) // normalize "#tag" -> "tag"
              .filter(Boolean)
              .map((t) => [t.toLowerCase(), t])
          ).values()
        ),
        hidden: !!p.hidden,
        x: 0,
        y: 0,
        vx: 0,
        vy: 0,
      }));
      layoutCircle();
    }

    function resize() {
      const wrap = canvas.parentElement;
      // Use clientWidth/clientHeight to exclude the 1px border on .kg__canvas-wrap.
      // getBoundingClientRect() includes borders, which would add 2px every cycle
      // and cause the canvas to grow indefinitely.
      const w = wrap ? wrap.clientWidth : 300;
      const h = wrap ? wrap.clientHeight : 150;
      currentDpr = Math.min(window.devicePixelRatio || 1, 2);
      const cw = Math.max(320, w);
      const ch = Math.max(400, h);
      canvas.width = Math.floor(cw * currentDpr);
      canvas.height = Math.floor(ch * currentDpr);
      canvas.style.width = `${cw}px`;
      canvas.style.height = `${ch}px`;
      ctx.setTransform(currentDpr, 0, 0, currentDpr, 0, 0);
    }

    let scale = 1;
    let panX = 0;
    let panY = 0;
    let currentDpr = Math.min(window.devicePixelRatio || 1, 2);

    let dragNode = null;
    let dragOffX = 0;
    let dragOffY = 0;
    let panDrag = false;
    let panStartX = 0;
    let panStartY = 0;
    let panStartClientX = 0;
    let panStartClientY = 0;
    let panOriginX = 0;
    let panOriginY = 0;
    let hoverNode = null;
    let hoverScreenX = 0;
    let hoverScreenY = 0;
    let settleTicks = 520;
    let settled = false;

    function wake() {
      settled = false;
      settleTicks = 520;
    }

    function clampPan() {
      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      // Allow some panning, but prevent the whole graph from being flung off-canvas.
      const slack = 160;
      const maxX = w * 0.55 * scale + slack;
      const maxY = h * 0.55 * scale + slack;
      panX = Math.max(-maxX, Math.min(maxX, panX));
      panY = Math.max(-maxY, Math.min(maxY, panY));
    }

    function screenToWorld(sx, sy) {
      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      const cx = w / 2;
      const cy = h / 2;
      return {
        x: (sx - cx - panX) / scale + cx,
        y: (sy - cy - panY) / scale + cy,
      };
    }

    function kindEnabled(k) {
      if (k === "markdown") return chkMd?.checked !== false;
      if (k === "wikilink") return chkWiki?.checked !== false;
      if (k === "tag") return chkTag?.checked !== false;
      return true;
    }

    function activeEdges() {
      return edges.filter((e) => (e.kinds || []).some((k) => kindEnabled(k)));
    }

    function buildComponents(adj) {
      // Connected components under current edge filter.
      const neighbors = new Map();
      for (const n of nodes) neighbors.set(n.id, []);
      for (const e of adj) {
        if (!neighbors.has(e.source)) neighbors.set(e.source, []);
        if (!neighbors.has(e.target)) neighbors.set(e.target, []);
        neighbors.get(e.source).push(e.target);
        neighbors.get(e.target).push(e.source);
      }

      const compId = new Map();
      const comps = [];
      let cid = 0;
      for (const n of nodes) {
        if (compId.has(n.id)) continue;
        const queue = [n.id];
        compId.set(n.id, cid);
        const members = [];
        while (queue.length) {
          const cur = queue.pop();
          members.push(cur);
          const nbrs = neighbors.get(cur) || [];
          for (const nb of nbrs) {
            if (!compId.has(nb)) {
              compId.set(nb, cid);
              queue.push(nb);
            }
          }
        }
        comps.push({ id: cid, members });
        cid += 1;
      }
      // biggest components first (helps placement)
      comps.sort((a, b) => b.members.length - a.members.length);
      // reindex to match sorted order
      const remap = new Map();
      comps.forEach((c, i) => remap.set(c.id, i));
      for (const [k, v] of compId) compId.set(k, remap.get(v));
      comps.forEach((c) => (c.id = remap.get(c.id)));
      comps.sort((a, b) => a.id - b.id);
      return { compId, comps };
    }

    function computeComponentAnchors(comps) {
      // Place components on a loose grid around center.
      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      const cx = w / 2;
      const cy = h / 2;
      const count = comps.length;
      const cols = Math.max(1, Math.ceil(Math.sqrt(count)));
      const rows = Math.max(1, Math.ceil(count / cols));
      const stepX = Math.max(260, Math.min(520, w / Math.max(1, cols)));
      const stepY = Math.max(220, Math.min(460, h / Math.max(1, rows)));

      const anchors = new Map();
      for (let i = 0; i < count; i++) {
        const r = Math.floor(i / cols);
        const c = i % cols;
        const x = cx + (c - (cols - 1) / 2) * stepX;
        const y = cy + (r - (rows - 1) / 2) * stepY;
        anchors.set(i, { x, y });
      }
      return anchors;
    }

    function filterQuery() {
      return String(filterInput?.value || "")
        .trim()
        .toLowerCase();
    }

    function simulate(iterations) {
      const q = filterQuery();
      const adj = activeEdges();
      const index = new Map(nodes.map((n, i) => [n.id, i]));
      const kRep = 1320; // stronger repulsion => more dispersion
      const kSpring = 0.040;
      const restLen = 156; // longer springs => more spacing
      const centerPull = 0.0075; // weaker centering => less clustering
      const centerPullIso = 0.003; // isolated nodes: much weaker centering
      const isoOutward = 0.012; // isolated nodes: mild outward push
      const damping = 0.86;
      const crossStrength = 0.11;
      const vMax = 22; // cap velocity to avoid runaway spin/jitter
      const compPull = 0.020; // pull nodes toward their component anchor
      const compSep = 1.30; // scale separation between components

      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      const cx = w / 2;
      const cy = h / 2;

      const { compId, comps } = buildComponents(adj);
      const anchors = computeComponentAnchors(comps);

      const degree = buildDegreeMap(adj);

      for (let it = 0; it < iterations; it++) {
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i];
            const b = nodes[j];
            let dx = b.x - a.x;
            let dy = b.y - a.y;
            let dist = Math.hypot(dx, dy) || 0.01;
            // Repulsion between different components is stronger to prevent tangling.
            const ca = compId.get(a.id) ?? 0;
            const cb = compId.get(b.id) ?? 0;
            const sep = ca === cb ? 1 : compSep;
            const force = (kRep * sep) / (dist * dist);
            dx /= dist;
            dy /= dist;
            if (dragNode !== a) {
              a.vx -= dx * force;
              a.vy -= dy * force;
            }
            if (dragNode !== b) {
              b.vx += dx * force;
              b.vy += dy * force;
            }
          }
        }

        for (const e of adj) {
          const ia = index.get(e.source);
          const ib = index.get(e.target);
          if (ia === undefined || ib === undefined) continue;
          const a = nodes[ia];
          const b = nodes[ib];
          let dx = b.x - a.x;
          let dy = b.y - a.y;
          const dist = Math.hypot(dx, dy) || 0.01;
          const delta = dist - restLen;
          const force = delta * kSpring;
          dx /= dist;
          dy /= dist;
          if (dragNode !== a) {
            a.vx += dx * force;
            a.vy += dy * force;
          }
          if (dragNode !== b) {
            b.vx -= dx * force;
            b.vy -= dy * force;
          }
        }

        // Heuristic: reduce edge crossings to improve readability.
        // Only apply during settling period (otherwise it may keep injecting angular momentum).
        if (settleTicks > 0 && (it % 2 === 0)) {
          const alpha = Math.min(1, settleTicks / 420);
          applyCrossingForces(adj, index, crossStrength * alpha);
        }

        for (const n of nodes) {
          if (n === dragNode) continue;
          const isIso = (degree.get(n.id) || 0) === 0;
          const pull = isIso ? centerPullIso : centerPull;
          n.vx += (cx - n.x) * pull;
          n.vy += (cy - n.y) * pull;
          if (isIso) {
            // Nudge isolated nodes outward so they orbit the main cluster.
            const dx = n.x - cx;
            const dy = n.y - cy;
            const dist = Math.hypot(dx, dy) || 1;
            n.vx += (dx / dist) * isoOutward;
            n.vy += (dy / dist) * isoOutward;
          }

          // Pull node toward its component anchor so different subgraphs stay separated.
          const c = compId.get(n.id) ?? 0;
          const a = anchors.get(c);
          if (a) {
            n.vx += (a.x - n.x) * compPull;
            n.vy += (a.y - n.y) * compPull;
          }

          const dim =
            q &&
            !`${n.title} ${n.collection}`.toLowerCase().includes(q);
          if (dim) {
            n.vx *= 0.72;
            n.vy *= 0.72;
          }
          n.x += n.vx;
          n.y += n.vy;
          n.vx *= damping;
          n.vy *= damping;
          const v = Math.hypot(n.vx, n.vy);
          if (v > vMax) {
            n.vx = (n.vx / v) * vMax;
            n.vy = (n.vy / v) * vMax;
          }
        }
      }
      if (settleTicks > 0) settleTicks = Math.max(0, settleTicks - iterations);
    }

    function pickNode(wx, wy) {
      for (let i = nodes.length - 1; i >= 0; i--) {
        const n = nodes[i];
        if (Math.hypot(wx - n.x, wy - n.y) <= 14) return n;
      }
      return null;
    }

    function buildDegreeMap(adj) {
      const deg = new Map();
      for (const e of adj) {
        deg.set(e.source, (deg.get(e.source) || 0) + 1);
        deg.set(e.target, (deg.get(e.target) || 0) + 1);
      }
      return deg;
    }

    function segIntersect(ax, ay, bx, by, cx, cy, dx, dy) {
      // Proper segment intersection test (excluding collinear overlap).
      const abx = bx - ax, aby = by - ay;
      const acx = cx - ax, acy = cy - ay;
      const adx = dx - ax, ady = dy - ay;
      const cdx = dx - cx, cdy = dy - cy;
      const cax = ax - cx, cay = ay - cy;
      const cbx = bx - cx, cby = by - cy;
      const cross1 = abx * acy - aby * acx;
      const cross2 = abx * ady - aby * adx;
      const cross3 = cdx * cay - cdy * cax;
      const cross4 = cdx * cby - cdy * cbx;
      if (cross1 === 0 && cross2 === 0 && cross3 === 0 && cross4 === 0) return false;
      return (cross1 > 0) !== (cross2 > 0) && (cross3 > 0) !== (cross4 > 0);
    }

    function applyCrossingForces(adj, index, strength) {
      // Best-effort crossing minimization (heuristic).
      const E = adj.length;
      if (E < 10) return;
      const maxChecks = E > 240 ? 2600 : Math.min(2600, (E * (E - 1)) / 2);

      for (let t = 0; t < maxChecks; t++) {
        const ei = adj[(Math.random() * E) | 0];
        const ej = adj[(Math.random() * E) | 0];
        if (!ei || !ej || ei === ej) continue;
        // Skip if sharing endpoints.
        if (ei.source === ej.source || ei.source === ej.target || ei.target === ej.source || ei.target === ej.target) continue;

        const ia = index.get(ei.source), ib = index.get(ei.target);
        const ic = index.get(ej.source), id = index.get(ej.target);
        if (ia === undefined || ib === undefined || ic === undefined || id === undefined) continue;
        const a = nodes[ia], b = nodes[ib], c = nodes[ic], d = nodes[id];

        if (!segIntersect(a.x, a.y, b.x, b.y, c.x, c.y, d.x, d.y)) continue;

        // Push endpoints apart perpendicular to each segment direction.
        const abx = b.x - a.x, aby = b.y - a.y;
        const cdx = d.x - c.x, cdy = d.y - c.y;
        const abLen = Math.hypot(abx, aby) || 1;
        const cdLen = Math.hypot(cdx, cdy) || 1;
        const pabx = -aby / abLen, paby = abx / abLen;
        const pcdx = -cdy / cdLen, pcdy = cdx / cdLen;

        const s = strength * (0.65 + Math.random() * 0.7);
        if (dragNode !== a) { a.vx += pabx * s; a.vy += paby * s; }
        if (dragNode !== b) { b.vx -= pabx * s; b.vy -= paby * s; }
        if (dragNode !== c) { c.vx += pcdx * s; c.vy += pcdy * s; }
        if (dragNode !== d) { d.vx -= pcdx * s; d.vy -= pcdy * s; }
      }
    }

    function drawTooltip(wx, wy, sx, sy, n) {
      const title = String(n.title || "");
      const uniqueTags = Array.isArray(n.tags)
        ? Array.from(new Map(n.tags.map((t) => [String(t ?? "").trim().toLowerCase(), String(t ?? "").trim()])).values()).filter(Boolean)
        : [];
      const tags = uniqueTags.length ? uniqueTags.slice(0, 6).join(" · ") : "";
      const lines = tags ? [title, tags] : [title];

      const padX = 10;
      const padY = 8;
      const titleSize = 14;
      const subSize = 13;
      const lineH = 18;
      ctx.save();
      // Keep tooltip sized in CSS pixels even on high-DPI screens.
      ctx.setTransform(currentDpr, 0, 0, currentDpr, 0, 0);
      ctx.font = `${titleSize}px ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial`;
      let w = 0;
      for (const line of lines) w = Math.max(w, ctx.measureText(line).width);
      const boxW = Math.min(w + padX * 2, 420);
      const boxH = padY * 2 + lineH * lines.length + (lines.length > 1 ? 2 : 0);

      const rect = canvas.getBoundingClientRect();
      let x = rect.left + sx + 14;
      let y = rect.top + sy + 14;
      const maxX = rect.left + rect.width - boxW - 12;
      const maxY = rect.top + rect.height - boxH - 12;
      x = Math.min(x, maxX);
      y = Math.min(y, maxY);
      x = Math.max(x, rect.left + 12);
      y = Math.max(y, rect.top + 12);

      const localX = x - rect.left;
      const localY = y - rect.top;

      // rounded rect
      ctx.beginPath();
      const r = 10;
      const x0 = localX, y0 = localY, x1 = localX + boxW, y1 = localY + boxH;
      ctx.moveTo(x0 + r, y0);
      ctx.arcTo(x1, y0, x1, y1, r);
      ctx.arcTo(x1, y1, x0, y1, r);
      ctx.arcTo(x0, y1, x0, y0, r);
      ctx.arcTo(x0, y0, x1, y0, r);
      ctx.closePath();
      ctx.fillStyle = THEME_TOOLTIP_BG;
      ctx.fill();
      ctx.strokeStyle = THEME_TOOLTIP_BD;
      ctx.lineWidth = 1;
      ctx.stroke();

      // text
      ctx.fillStyle = THEME_TEXT;
      ctx.textBaseline = "top";
      ctx.font = `600 ${titleSize}px ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial`;
      ctx.fillText(lines[0], localX + padX, localY + padY);
      if (lines.length > 1) {
        ctx.fillStyle = "rgba(148, 163, 184, 0.92)";
        ctx.font = `${subSize}px ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial`;
        ctx.fillText(lines[1], localX + padX, localY + padY + lineH);
      }
      ctx.restore();
    }

    function draw() {
      const w = canvas.width / currentDpr;
      const h = canvas.height / currentDpr;
      ctx.save();
      ctx.clearRect(0, 0, w, h);

      const cx = w / 2;
      const cy = h / 2;
      ctx.translate(cx + panX, cy + panY);
      ctx.scale(scale, scale);
      ctx.translate(-cx, -cy);

      ctx.strokeStyle = "rgba(148, 163, 184, 0.14)";
      ctx.lineWidth = 1 / scale;

      const q = filterQuery();
      const adj = activeEdges();
      const dimAll = !!q;
      const degree = buildDegreeMap(adj);
      const maxDeg = Math.max(1, ...degree.values());

      for (const e of adj) {
        const a = nodes.find((n) => n.id === e.source);
        const b = nodes.find((n) => n.id === e.target);
        if (!a || !b) continue;

        const kinds = e.kinds || [];
        let stroke = "rgba(148, 163, 184, 0.35)";
        if (kinds.includes("markdown")) stroke = "rgba(56, 189, 248, 0.42)";
        else if (kinds.includes("wikilink")) stroke = "rgba(167, 139, 250, 0.45)";
        else if (kinds.includes("tag")) stroke = "rgba(148, 163, 184, 0.28)";

        const faded =
          dimAll &&
          (!`${a.title} ${a.collection}`.toLowerCase().includes(q) ||
            !`${b.title} ${b.collection}`.toLowerCase().includes(q));

        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = faded ? "rgba(148, 163, 184, 0.07)" : stroke;
        ctx.setLineDash(kinds.includes("tag") && kinds.length === 1 ? [5 / scale, 4 / scale] : []);
        ctx.stroke();
        ctx.setLineDash([]);
      }

      for (const n of nodes) {
        const match = !dimAll || `${n.title} ${n.collection}`.toLowerCase().includes(q);
        const deg = degree.get(n.id) || 0;
        const importance = Math.min(1, deg / maxDeg);
        const alpha = match ? (n.hidden ? 0.55 : 0.95) : 0.16;
        const radius = (n.hidden ? 5.6 : 6.4) + importance * (n.hidden ? 1.2 : 3.2);
        ctx.beginPath();
        ctx.arc(n.x, n.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = match
          ? (n.hidden ? THEME_NODE_HIDDEN : nodeColor(n.collection))
          : nodeColorDim(n.collection);
        ctx.fill();
        if (n.hidden) {
          ctx.strokeStyle = `rgba(248, 113, 113, ${Math.max(0.2, alpha * 0.8)})`;
          ctx.lineWidth = 1.25 / scale;
          ctx.stroke();
        }
        if (hoverNode === n) {
          ctx.strokeStyle = "rgba(255,255,255,0.50)";
          ctx.lineWidth = 1.15 / scale;
          ctx.stroke();
        }
        if (dragNode === n) {
          ctx.strokeStyle = "rgba(255,255,255,0.38)";
          ctx.lineWidth = 1 / scale;
          ctx.stroke();
        }
      }

      // tag labels (keep light to avoid clutter)
      if (scale >= 0.9) {
        const maxTags = scale >= 1.45 ? 2 : 1;
        ctx.font = `${Math.max(10, Math.min(12, 11 * scale))}px ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial`;
        ctx.textBaseline = "top";
        for (const n of nodes) {
          const match = !dimAll || `${n.title} ${n.collection}`.toLowerCase().includes(q);
          if (!match) continue;
          const tags = Array.from(
            new Map(
              (n.tags || [])
                .map((t) => String(t ?? "").trim())
                .filter(Boolean)
                .map((t) => [t.toLowerCase(), t])
            ).values()
          ).slice(0, maxTags);
          if (!tags.length) continue;
          const label = tags.map((t) => `#${t}`).join(" ");
          ctx.fillStyle = THEME_TEXT;
          ctx.globalAlpha = n.hidden ? 0.52 : 0.78;
          ctx.fillText(label, n.x + 10, n.y + 8);
          ctx.globalAlpha = 1;
        }
      }

      ctx.restore();

      // tooltip drawn in screen space so it never gets clipped by transforms
      if (hoverNode) {
        drawTooltip(hoverNode.x, hoverNode.y, hoverScreenX, hoverScreenY, hoverNode);
      }
    }

    let running = true;
    function loop() {
      if (!running) return;
      if (!dragNode && !panDrag && (!settled || settleTicks > 0)) {
        simulate(2);
        if (settleTicks <= 0) settled = true;
      }
      draw();
      requestAnimationFrame(loop);
    }

    function clientCoords(ev) {
      const rect = canvas.getBoundingClientRect();
      return { x: ev.clientX - rect.left, y: ev.clientY - rect.top };
    }

    canvas.addEventListener(
      "wheel",
      (ev) => {
        ev.preventDefault();
        const { x, y } = clientCoords(ev);
        const factor = ev.deltaY > 0 ? 0.9 : 1.11;
        const prevScale = scale;
        scale = Math.min(3.2, Math.max(0.35, scale * factor));
        const w = canvas.width / currentDpr;
        const h = canvas.height / currentDpr;
        const cx = w / 2;
        const cy = h / 2;
        const wx = (x - cx - panX) / prevScale + cx;
        const wy = (y - cy - panY) / prevScale + cy;
        panX = x - cx - (wx - cx) * scale;
        panY = y - cy - (wy - cy) * scale;
        clampPan();
      },
      { passive: false }
    );

    canvas.addEventListener("mousedown", (ev) => {
      const { x, y } = clientCoords(ev);
      const w = screenToWorld(x, y);
      const hit = pickNode(w.x, w.y);
      if (hit) {
        dragNode = hit;
        dragOffX = w.x - hit.x;
        dragOffY = w.y - hit.y;
        hit.vx = 0;
        hit.vy = 0;
        hoverNode = hit;
        hoverScreenX = x;
        hoverScreenY = y;
      } else {
        panDrag = true;
        panStartX = x;
        panStartY = y;
        panStartClientX = ev.clientX;
        panStartClientY = ev.clientY;
        panOriginX = panX;
        panOriginY = panY;
        canvas.classList.add("kg__canvas--drag");
      }
    });

    window.addEventListener("mouseup", () => {
      if (dragNode) wake();
      dragNode = null;
      panDrag = false;
      canvas.classList.remove("kg__canvas--drag");
    });

    window.addEventListener("mousemove", (ev) => {
      if (dragNode) {
        const { x, y } = clientCoords(ev);
        const w = screenToWorld(x, y);
        dragNode.x = w.x - dragOffX;
        dragNode.y = w.y - dragOffY;
        hoverScreenX = x;
        hoverScreenY = y;
      } else if (panDrag) {
        panX = panOriginX + (ev.clientX - panStartClientX);
        panY = panOriginY + (ev.clientY - panStartClientY);
        clampPan();
      }
    });

    canvas.addEventListener("mousemove", (ev) => {
      if (dragNode || panDrag) return;
      const { x, y } = clientCoords(ev);
      hoverScreenX = x;
      hoverScreenY = y;
      const w = screenToWorld(x, y);
      const hit = pickNode(w.x, w.y);
      hoverNode = hit;
      canvas.style.cursor = hit ? "pointer" : "grab";
    });

    canvas.addEventListener("mouseleave", () => {
      if (dragNode) return;
      hoverNode = null;
      canvas.style.cursor = "grab";
    });

    canvas.addEventListener("dblclick", (ev) => {
      const { x, y } = clientCoords(ev);
      const w = screenToWorld(x, y);
      const hit = pickNode(w.x, w.y);
      if (!hit) return;
      const post = (payload.nodes || []).find((p) => p.id === hit.id);
      if (post?.href) {
        const b = String(baseUrl || "/").replace(/\/$/, "");
        const p = String(post.href).replace(/^\/+/, "");
        const url = b ? `${b}/${p}` : `/${p}`;
        window.open(url, "_blank", "noopener,noreferrer");
      }
    });

    chkMd?.addEventListener("change", () => { wake(); simulate(40); });
    chkWiki?.addEventListener("change", () => { wake(); simulate(40); });
    chkTag?.addEventListener("change", () => { wake(); simulate(40); });
    filterInput?.addEventListener("input", () => {});
    btnReset?.addEventListener("click", () => {
      layoutCircle();
      scale = 1;
      panX = 0;
      panY = 0;
      clampPan();
      wake();
      simulate(420);
    });

    resize();
    // Detect whether the canvas got real dimensions. If the tab starts hidden
    // (display:none), resize() falls back to minimums (320x400); let the
    // ResizeObserver do the real init later.
    const initW = canvas.width / currentDpr;
    const initH = canvas.height / currentDpr;
    const wasHidden = initW <= 340 && initH <= 420;
    initNodes();
    clampPan();
    simulate(520);
    loop();
    let graphInitialized = !wasHidden;
    const wrap = canvas.parentElement;
    if (wrap && "ResizeObserver" in window) {
      let lastW = 0;
      let lastH = 0;
      const ro = new ResizeObserver((entries) => {
        const cr = entries[0]?.contentRect;
        const nw = Math.floor(cr?.width || 0);
        const nh = Math.floor(cr?.height || 0);
        if (nw < 10 || nh < 10) return;
        if (Math.abs(nw - lastW) < 2 && Math.abs(nh - lastH) < 2) return;
        lastW = nw;
        lastH = nh;
        resize();
        clampPan();
        // Full re-init only on first reveal (when tab becomes visible).
        // Subsequent resizes only update canvas dimensions and clamp.
        if (!graphInitialized) {
          graphInitialized = true;
          scale = 1;
          panX = 0;
          panY = 0;
          layoutCircle();
          wake();
          simulate(420);
        }
      });
      ro.observe(wrap);
    } else {
      // Fallback: retry a few times after load (covers tab activation without RO).
      let tries = 0;
      const tick = () => {
        tries += 1;
        const rect = canvas.getBoundingClientRect();
        if (rect.width > 40 && rect.height > 40) {
          graphInitialized = true;
          resize();
          scale = 1;
          panX = 0;
          panY = 0;
          clampPan();
          layoutCircle();
          wake();
          simulate(320);
          return;
        }
        if (tries < 12) setTimeout(tick, 250);
      };
      setTimeout(tick, 250);
    }

    window.addEventListener("resize", () => {
      resize();
      clampPan();
    });
  })();
</script>
