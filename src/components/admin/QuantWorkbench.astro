---
const projectModules = [
  {
    title: "Backend project",
    items: [
      "`quant_backend/app/main.py` - FastAPI entry",
      "`quant_backend/app/api/backtests.py` - run/result endpoints",
      "`quant_backend/app/api/health.py` - runtime health",
      "`quant_backend/app/services/data_loader.py` - demo data loading",
      "`quant_backend/app/services/factor_engine.py` - factor generation",
      "`quant_backend/app/services/backtest_engine.py` - backtest execution",
      "`quant_backend/app/services/report_builder.py` - metrics + output formatting",
    ],
  },
  {
    title: "Data / compute",
    items: [
      "Use local CSV or Parquet first so the full chain can run without external dependencies.",
      "Keep Python as the first runnable engine; plug C++ factor core in later behind the same service layer.",
      "Treat `quant/psi-trader-zhangboxuan/` as a performance track, not phase-one dependency.",
    ],
  },
  {
    title: "Frontend panel",
    items: [
      "Admin Quant tab triggers backtests through FastAPI.",
      "Runtime tab checks `${API_BASE}/health` and `${API_BASE}/backtests/recent`.",
      "Results stay inside admin instead of separate hidden pages.",
    ],
  },
];
const youBuild = [
  "准备一份可重复读取的 demo 行情数据集。",
  "实现最小策略链路：数据读取 → 因子 → 排名/选股 → 回测 → metrics。",
  "保证 FastAPI 至少返回 job id、result metrics、recent jobs、health。",
  "用同一套字段把 AI 输出接到 quant 输入，不再人工搬运。",
];
const flowSteps = [
  "Admin Quant tab 填参数",
  "POST /backtests/run 启动任务",
  "FastAPI 读取数据并执行回测",
  "GET /backtests/{job_id}/result 拉取结果",
  "Admin 展示收益、夏普、回撤、胜率、换手率",
  "Runtime tab 监控 API 状态和最近任务",
];
---

<div class="quant-workbench">
  <div class="quant-hero">
    <h1 class="quant-title">Quant Execution Console</h1>
    <p class="quant-subtitle">目标不是慢慢学，而是先把一条完整主链路跑通：admin → FastAPI → backtest → metrics → admin。</p>
  </div>

  <div class="quant-focus">
    <span>FastAPI</span>
    <span>Backtest Engine</span>
    <span>Factor Pipeline</span>
    <span>Runtime Health</span>
    <span>C++ Core Later</span>
  </div>

  <div class="quant-section">
    <h2>建议新建 / 规范的项目结构</h2>
    <div class="quant-tracks">
      {projectModules.map((module) => (
        <section class="quant-track">
          <h2>{module.title}</h2>
          <ul>
            {module.items.map((item) => <li set:html={item}></li>)}
          </ul>
        </section>
      ))}
    </div>
  </div>

  <div class="quant-section">
    <h2>你现在要做什么</h2>
    <ul>
      {youBuild.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <div class="quant-section">
    <h2>整条链路怎么接</h2>
    <ol class="quant-flow">
      {flowSteps.map((item) => <li>{item}</li>)}
    </ol>
    <p class="quant-tip">后端启动命令：<code>cd quant_backend && uvicorn app.main:app --host 127.0.0.1 --port 8000</code></p>
  </div>

  <div class="backtest-runner">
    <h3>📊 回测引擎</h3>
    <form class="backtest-form" id="backtest-form">
      <label>策略
        <select name="strategy">
          <option value="momentum_demo">动量策略 (Demo)</option>
          <option value="mean_reversion_demo">均值回归 (Demo)</option>
          <option value="factor_rank_demo">因子排名 (Demo)</option>
        </select>
      </label>
      <label>开始日期
        <input type="date" name="start_date" value="2024-01-01" />
      </label>
      <label>结束日期
        <input type="date" name="end_date" value="2024-12-31" />
      </label>
      <label>调仓频率
        <select name="rebalance_freq">
          <option value="daily">每日</option>
          <option value="weekly" selected>每周</option>
          <option value="monthly">每月</option>
        </select>
      </label>
      <label>Top N
        <input type="number" name="top_n" value="10" min="1" max="50" />
      </label>
      <button type="submit">运行回测</button>
    </form>
    <div id="backtest-results"></div>
  </div>
</div>
