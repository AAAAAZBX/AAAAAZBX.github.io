---
import type { MergedPost } from "../lib/content-posts";
import { buildPostExcerpt, formatDateIso } from "../lib/content-posts";
import {
  buildContentFolderDisplayMap,
  categoryIndexHref,
  normSeg,
} from "../lib/category-tree";
import { HOME_POSTS_PER_PAGE } from "../lib/home-pagination";

interface Props {
  recentPosts: MergedPost[];
  currentPage: number;
  totalPages: number;
}

type RuntimeHomePost = {
  sortId: string;
  title: string;
  date: string;
  dateFormatted: string;
  href: string;
  excerpt: string;
  crumbs: Array<{ label: string; href: string }>;
  tags: Array<{ label: string; href: string }>;
};

const { recentPosts, currentPage, totalPages } = Astro.props;

const heroTypedText = "Algorithms, Systems, and Machine Learning";
const heroIntro =
  "Rigorous notes, small experiments, and things worth coming back to.";
const heroImageUrl = `${import.meta.env.BASE_URL}site-profile.png`;
const folderDisplayMap = buildContentFolderDisplayMap();
const baseUrl = import.meta.env.BASE_URL;

function homePageHref(page: number): string {
  if (page <= 1) return baseUrl;
  const path = `page/${page}`;
  return baseUrl.endsWith("/") ? `${baseUrl}${path}` : `${baseUrl}/${path}`;
}

function baseJoin(path: string): string {
  const clean = path.replace(/^\/+/, "");
  return baseUrl.endsWith("/") ? `${baseUrl}${clean}` : `${baseUrl}/${clean}`;
}

function tagSlug(tag: string): string {
  return tag.trim().toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9一-鿿_-]/g, "");
}

function categoryArchiveCrumbs(collection: string, slug: string): Array<{ label: string; href: string }> {
  const dirs = slug.split("/").filter(Boolean).slice(0, -1);
  const crumbs = [
    {
      label: collection,
      href: categoryIndexHref(baseUrl, collection),
    },
  ];

  dirs.forEach((seg, idx) => {
    const pathKey = `${collection}/${dirs.slice(0, idx + 1).map(normSeg).join("/")}`;
    crumbs.push({
      label: folderDisplayMap.get(pathKey) ?? seg,
      href: categoryIndexHref(baseUrl, pathKey),
    });
  });

  return crumbs;
}

function toRuntimePost(post: MergedPost): RuntimeHomePost {
  return {
    sortId: post.sortId,
    title: post.title,
    date: post.date ?? "",
    dateFormatted: formatDateIso(post.date),
    href: post.href,
    excerpt: buildPostExcerpt(post.body),
    crumbs: categoryArchiveCrumbs(post.collection, post.slug),
    tags: (post.tags ?? []).map((tag) => ({
      label: tag,
      href: `${baseJoin("tags")}/${encodeURIComponent(tagSlug(tag))}`,
    })),
  };
}

const initialRuntimePosts = recentPosts.map(toRuntimePost);
const showPagination = totalPages > 1;
const prevHref = currentPage > 1 ? homePageHref(currentPage - 1) : null;
const nextHref = currentPage < totalPages ? homePageHref(currentPage + 1) : null;
---

<div class="fluid-index-header-inner fluid-index-header-home">
  <div id="banner" class="fluid-banner fluid-banner-photo-mode">
    <div class="fluid-banner-bg" aria-hidden="true">
      <img
        class="fluid-banner-photo"
        src={heroImageUrl}
        alt=""
        width="1440"
        height="1080"
        decoding="async"
        fetchpriority="high"
      />
    </div>
    <div class="fluid-banner-inner">
      <div class="fluid-banner-mask">
        <div class="fluid-banner-text">
          <h1
            class="fluid-banner-title"
            lang="en"
            aria-label={heroTypedText}
            aria-describedby="fluid-hero-intro"
          >
            <span id="fluid-hero-typed" data-typed-text={heroTypedText}></span>
          </h1>
          <p class="fluid-banner-subtitle" id="fluid-hero-intro">
            {heroIntro}
          </p>
        </div>
        <a
          href="#fluid-board"
          class="fluid-scroll-down"
          aria-label="Scroll to recent posts"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<main id="fluid-board" class="fluid-index-main fluid-board-page">
  <div class="fluid-container fluid-nopadding-x-md">
    <div id="board" class="fluid-board-surface fluid-board-home">
      <div class="fluid-container">
        <div class="fluid-row">
          <div class="fluid-col-12 fluid-col-md-10 fluid-m-auto">
            <div
              class="home-feed"
              data-home-page={currentPage}
              data-home-total-pages={totalPages}
              data-home-posts-per-page={HOME_POSTS_PER_PAGE}
              data-home-runtime-endpoint={baseJoin("home-posts.json")}
              data-home-visibility-endpoint={baseJoin("api/visibility")}
              data-home-supabase-url={import.meta.env.PUBLIC_SUPABASE_URL ?? ""}
              data-home-supabase-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ""}
              data-home-base-url={baseUrl}
            >
              <ul class="home-post-list">
                {recentPosts.map((item) => (
                  <li class="home-post-item index-card-mimic" data-post-id={item.sortId}>
                    <a class="home-post-link" href={item.href}>
                      <span class="home-post-title">{item.title}</span>
                    </a>
                    <a class="home-post-excerpt-link" href={item.href}>
                      <p class="home-post-excerpt">{buildPostExcerpt(item.body)}</p>
                    </a>
                    <div class="home-post-meta">
                      <span class="home-post-meta-item">
                        <i class="iconfont icon-date" aria-hidden="true"></i>
                        <time class="home-post-date" datetime={item.date ?? ""}>
                          {formatDateIso(item.date)}
                        </time>
                      </span>
                      <span class="home-post-meta-item">
                        <i class="iconfont icon-category-fill" aria-hidden="true"></i>
                        <span class="home-post-cat">
                          {categoryArchiveCrumbs(item.collection, item.slug).map((crumb, idx) => (
                            <>
                              {idx > 0 && <span class="home-post-cat-separator"> &gt; </span>}
                              <a class="home-post-meta-link" href={crumb.href}>
                                {crumb.label}
                              </a>
                            </>
                          ))}
                        </span>
                      </span>
                      {item.tags.length > 0 && (
                        <span class="home-post-meta-item">
                          <i class="iconfont icon-tags-fill" aria-hidden="true"></i>
                          <span class="home-post-tags">
                            {item.tags.map((tag, idx) => (
                              <>
                                {idx > 0 && "  "}
                                <a
                                  class="home-post-meta-link home-post-tag-link"
                                  href={`${baseJoin("tags")}/${encodeURIComponent(tagSlug(tag))}`}
                                >
                                  #{tag}
                                </a>
                              </>
                            ))}
                          </span>
                        </span>
                      )}
                    </div>
                  </li>
                ))}
              </ul>

              <p class="home-empty" style={recentPosts.length === 0 ? undefined : "display:none"}>No posts yet.</p>

              {
                showPagination && (
                  <nav class="home-pagination" aria-label="Posts pagination">
                    {prevHref ? (
                      <a class="home-pagination-link home-pagination-prev" href={prevHref}>
                        ‹ Prev
                      </a>
                    ) : (
                      <span class="home-pagination-link home-pagination-prev is-disabled" aria-disabled="true">
                        ‹ Prev
                      </span>
                    )}
                    <span class="home-pagination-status">
                      {currentPage} / {totalPages}
                    </span>
                    {nextHref ? (
                      <a class="home-pagination-link home-pagination-next" href={nextHref}>
                        Next ›
                      </a>
                    ) : (
                      <span class="home-pagination-link home-pagination-next is-disabled" aria-disabled="true">
                        Next ›
                      </span>
                    )}
                  </nav>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline src="https://lib.baomitu.com/typed.js/2.0.12/typed.min.js"></script>
<script is:inline define:vars={{ currentPage, homePostsPerPage: HOME_POSTS_PER_PAGE }}>
  (function () {
    function fluidHeroTyping() {
      if (typeof window.Typed === "undefined") return;
      var el = document.getElementById("fluid-hero-typed");
      if (!el) return;
      var text = el.getAttribute("data-typed-text");
      if (!text) return;
      el.textContent = "";
      new window.Typed("#fluid-hero-typed", {
        strings: ["  ", text],
        typeSpeed: 50,
        cursorChar: "_",
        loop: false,
        showCursor: true,
      });
    }

    function fluidHeroParallax() {
      var hero = document.querySelector(".fluid-index-header-inner");
      var bg = document.querySelector(".fluid-banner.fluid-banner-photo-mode .fluid-banner-bg");
      if (!hero || !bg) return;

      var ticking = false;
      function update() {
        var top = window.pageYOffset || document.documentElement.scrollTop || 0;
        var heroH = hero.clientHeight || 1;
        var progress = Math.min(Math.max(top / heroH, 0), 1);
        var y = Math.round(top * 0.28);
        var scale = (1 + progress * 0.04).toFixed(3);
        bg.style.transform = "translate3d(0," + y + "px,0) scale(" + scale + ")";
        ticking = false;
      }

      function requestUpdate() {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      }

      window.addEventListener("scroll", requestUpdate, { passive: true });
      window.addEventListener("resize", requestUpdate);
      update();
    }

    function fluidBoardLift() {
      var hero = document.querySelector(".fluid-index-header-inner");
      var board = document.querySelector("#board.fluid-board-home");
      if (!hero || !board) return;

      var scrollSpanFactor = 0.52;
      var maxLiftPx = 112;
      var ticking = false;
      function update() {
        var top = window.pageYOffset || document.documentElement.scrollTop || 0;
        var heroH = hero.clientHeight || 1;
        var span = Math.max(heroH * scrollSpanFactor, 72);
        var progress = Math.min(Math.max(top / span, 0), 1);
        var lift = Math.round(progress * maxLiftPx);
        board.style.transform = "translate3d(0," + -lift + "px,0)";
        ticking = false;
      }

      function requestUpdate() {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      }

      window.addEventListener("scroll", requestUpdate, { passive: true });
      window.addEventListener("resize", requestUpdate);
      update();
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, function (ch) {
        return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" })[ch] || ch;
      });
    }

    function renderHomePost(item) {
      var crumbs = Array.isArray(item.crumbs) ? item.crumbs : [];
      var tags = Array.isArray(item.tags) ? item.tags : [];
      var crumbHtml = crumbs.map(function (crumb, idx) {
        var sep = idx > 0 ? '<span class="home-post-cat-separator"> &gt; </span>' : '';
        return sep + '<a class="home-post-meta-link" href="' + escapeHtml(crumb.href) + '">' + escapeHtml(crumb.label) + '</a>';
      }).join('');
      var tagsHtml = tags.length
        ? '<span class="home-post-meta-item"><i class="iconfont icon-tags-fill" aria-hidden="true"></i><span class="home-post-tags">' + tags.map(function (tag, idx) {
            var prefix = idx > 0 ? '  ' : '';
            return prefix + '<a class="home-post-meta-link home-post-tag-link" href="' + escapeHtml(tag.href) + '">#' + escapeHtml(tag.label) + '</a>';
          }).join('') + '</span></span>'
        : '';

      return '<li class="home-post-item index-card-mimic" data-post-id="' + escapeHtml(item.sortId) + '">' +
        '<a class="home-post-link" href="' + escapeHtml(item.href) + '"><span class="home-post-title">' + escapeHtml(item.title) + '</span></a>' +
        '<a class="home-post-excerpt-link" href="' + escapeHtml(item.href) + '"><p class="home-post-excerpt">' + escapeHtml(item.excerpt || '') + '</p></a>' +
        '<div class="home-post-meta">' +
          '<span class="home-post-meta-item"><i class="iconfont icon-date" aria-hidden="true"></i><time class="home-post-date" datetime="' + escapeHtml(item.date || '') + '">' + escapeHtml(item.dateFormatted || '') + '</time></span>' +
          '<span class="home-post-meta-item"><i class="iconfont icon-category-fill" aria-hidden="true"></i><span class="home-post-cat">' + crumbHtml + '</span></span>' +
          tagsHtml +
        '</div>' +
      '</li>';
    }

    function replacePaginationEdge(nav, selector, href, enabled) {
      var current = nav.querySelector(selector);
      if (!current) return;
      var replacement;
      if (enabled) {
        replacement = document.createElement('a');
        replacement.className = current.className.replace(/\bis-disabled\b/g, '').replace(/\s+/g, ' ').trim();
        replacement.href = href;
      } else {
        replacement = document.createElement('span');
        replacement.className = (current.className + ' is-disabled').replace(/\s+/g, ' ').trim();
        replacement.setAttribute('aria-disabled', 'true');
      }
      replacement.textContent = current.textContent || '';
      current.replaceWith(replacement);
    }

    function fetchHiddenIds(feed, supabaseUrl, supabaseKey) {
      var apiUrl = feed.getAttribute('data-home-visibility-endpoint') || '/api/visibility';
      var requests = [
        fetch(apiUrl, { cache: 'no-store' })
          .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
          .then(function (payload) {
            return Array.isArray(payload && payload.hidden)
              ? payload.hidden.map(function (s) { return String(s).trim().toLowerCase(); })
              : [];
          })
          .catch(function () { return []; })
      ];

      requests.push(
        (supabaseUrl && supabaseKey)
          ? fetch(supabaseUrl + '/rest/v1/content_visibility?select=hidden_posts&id=eq.1', {
              headers: { apikey: supabaseKey, Authorization: 'Bearer ' + supabaseKey }
            })
              .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
              .then(function (rows) {
                return (Array.isArray(rows) && rows[0] && Array.isArray(rows[0].hidden_posts))
                  ? rows[0].hidden_posts.map(function (s) { return String(s).trim().toLowerCase(); })
                  : [];
              })
              .catch(function () { return []; })
          : Promise.resolve([])
      );

      return Promise.all(requests).then(function (sources) {
        return Array.from(new Set([].concat.apply([], sources)));
      });
    }

    function renderRuntimeHome() {
      var feed = document.querySelector('.home-feed[data-home-runtime-endpoint]');
      if (!feed) return;
      var list = feed.querySelector('.home-post-list');
      var empty = feed.querySelector('.home-empty');
      var pagination = feed.querySelector('.home-pagination');
      if (!list || !empty) return;

      var endpoint = feed.getAttribute('data-home-runtime-endpoint') || '';
      var supabaseUrl = feed.getAttribute('data-home-supabase-url') || '';
      var supabaseKey = feed.getAttribute('data-home-supabase-key') || '';
      var page = Number(feed.getAttribute('data-home-page') || currentPage || 1) || 1;
      var perPage = Number(feed.getAttribute('data-home-posts-per-page') || homePostsPerPage) || homePostsPerPage;

      if (!endpoint) return;

      Promise.all([
        fetch(endpoint).then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); }),
        fetchHiddenIds(feed, supabaseUrl, supabaseKey)
      ]).then(function (results) {
        var catalogRows = results[0];
        var hidden = Array.isArray(results[1]) ? results[1] : [];
        var catalog = Array.isArray(catalogRows && catalogRows.posts) ? catalogRows.posts : [];
        var hiddenSet = new Set(hidden);
        var visiblePosts = catalog.filter(function (post) {
          return !hiddenSet.has(String(post.sortId || '').trim().toLowerCase());
        });
        var totalPagesRuntime = Math.max(1, Math.ceil(visiblePosts.length / perPage));
        var start = Math.max(0, (page - 1) * perPage);
        var currentPosts = visiblePosts.slice(start, start + perPage);

        list.innerHTML = currentPosts.map(renderHomePost).join('');
        empty.style.display = currentPosts.length ? 'none' : '';

        if (pagination) {
          pagination.style.display = totalPagesRuntime > 1 ? '' : 'none';
          var status = pagination.querySelector('.home-pagination-status');
          if (status) status.textContent = page + ' / ' + totalPagesRuntime;
          replacePaginationEdge(pagination, '.home-pagination-prev', homePageHref(page - 1), page > 1);
          replacePaginationEdge(pagination, '.home-pagination-next', homePageHref(page + 1), page < totalPagesRuntime);
        }
      }).catch(function () {
        // keep server-rendered fallback
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        fluidHeroTyping();
        fluidHeroParallax();
        fluidBoardLift();
        renderRuntimeHome();
      });
    } else {
      fluidHeroTyping();
      fluidHeroParallax();
      fluidBoardLift();
      renderRuntimeHome();
    }
  })();
</script>
