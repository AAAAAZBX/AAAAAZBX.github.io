---
// TableOfContents 组件：自动生成文章目录
---

<div id="toc-container" class="toc-container">
  <div class="toc-header">
    <h3>目录</h3>
  </div>
  <nav id="toc-nav" class="toc-nav">
    <!-- 目录项将通过 JavaScript 动态生成 -->
  </nav>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const article = document.querySelector("article.typora-github");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3, h4");
    if (headings.length === 0) {
      document.getElementById("toc-container")?.remove();
      return;
    }

    const tocNav = document.getElementById("toc-nav");
    if (!tocNav) return;

    const tocItems = [];

    headings.forEach((heading, index) => {
      // 为每个标题生成 ID
      const text = heading.textContent || "";
      let id = text
        .toLowerCase()
        .replace(/[^\w\s\u4e00-\u9fa5-]/g, "") // 保留中文、英文、数字、连字符
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-")
        .trim();
      
      // 如果 ID 为空或已存在，添加索引
      if (!id) {
        id = `heading-${index}`;
      }
      
      // 检查是否已存在相同 ID
      let finalId = id;
      let counter = 1;
      while (document.getElementById(finalId)) {
        finalId = `${id}-${counter}`;
        counter++;
      }

      heading.id = finalId;
      const level = parseInt(heading.tagName.charAt(1));
      tocItems.push({ id: finalId, text, level });
    });

    // 生成层级结构的目录 HTML
    let tocHTML = "";
    let prevLevel = 2; // 假设第一个是 h2
    let openTags = 0;

    tocItems.forEach((item, index) => {
      const level = item.level;
      
      if (index === 0) {
        // 第一个项目，打开初始 ul
        tocHTML += '<ul class="toc-root">';
        openTags = 1;
      } else {
        // 处理层级变化
        if (level > prevLevel) {
          // 进入更深层级，在当前的 li 内打开嵌套 ul
          tocHTML += '<ul class="toc-nested">';
          openTags++;
        } else if (level < prevLevel) {
          // 回到更浅层级，关闭嵌套的 ul 和 li
          const levelsToClose = prevLevel - level;
          for (let i = 0; i < levelsToClose; i++) {
            tocHTML += '</ul></li>';
            openTags -= 2;
          }
        } else {
          // 同级，关闭上一个 li
          tocHTML += '</li>';
          openTags--;
        }
      }

      const levelClass = `toc-level-${level}`;
      tocHTML += `<li class="toc-list-item ${levelClass}">`;
      tocHTML += `<a href="#${item.id}" class="toc-item">${item.text}</a>`;
      
      prevLevel = level;
    });

    // 关闭所有未关闭的标签
    while (openTags > 0) {
      if (openTags % 2 === 1) {
        tocHTML += '</li>';
      } else {
        tocHTML += '</ul>';
      }
      openTags--;
    }

    tocNav.innerHTML = tocHTML;

    // 添加平滑滚动（使用事件委托，因为结构是动态生成的）
    tocNav.addEventListener("click", (e) => {
      const link = e.target.closest("a.toc-item");
      if (!link) return;
      
      e.preventDefault();
      const targetId = link.getAttribute("href")?.substring(1);
      const target = document.getElementById(targetId || "");
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        // 使用 replaceState 而不是 pushState，避免在历史记录中留下锚点
        // 这样回退时会回到上一个网页，而不是上一个标题
        const url = window.location.pathname + (targetId ? `#${targetId}` : '');
        window.history.replaceState(null, "", url);
      }
    });

    // 高亮当前章节
    const observerOptions = {
      rootMargin: "-20% 0px -70% 0px",
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocNav.querySelectorAll("a.toc-item").forEach((link) => {
            link.classList.remove("active");
            if (link.getAttribute("href") === `#${id}`) {
              link.classList.add("active");
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach((heading) => observer.observe(heading));

    // 页面加载时，如果有锚点，高亮对应的目录项
    const updateActiveLink = () => {
      const hash = window.location.hash;
      tocNav.querySelectorAll("a.toc-item").forEach((link) => {
        link.classList.remove("active");
        if (hash && link.getAttribute("href") === hash) {
          link.classList.add("active");
        }
      });
    };

    // 初始状态
    updateActiveLink();

    // 监听浏览器前进/后退
    window.addEventListener("popstate", () => {
      updateActiveLink();
      // 如果有锚点，滚动到对应位置
      const hash = window.location.hash;
      if (hash) {
        const target = document.getElementById(hash.substring(1));
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }
    });
  });
</script>

<style>
  .toc-container {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 16px;
    margin-right: 32px;
    flex-shrink: 0;
    width: 240px;
  }

  .toc-header {
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e1e4e8;
  }

  .toc-header h3 {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: #24292f;
  }

  .toc-nav {
    position: relative;
    padding-left: 0;
  }

  .toc-nav > ul,
  .toc-root {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  .toc-nested {
    list-style: none;
    padding: 0;
    margin: 0;
    margin-left: 20px;
    margin-top: 4px;
    margin-bottom: 4px;
    position: relative;
    border-left: 1px solid #e1e4e8;
    padding-left: 12px;
  }

  /* 为嵌套列表添加左侧竖线 */
  .toc-nested::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background-color: #e1e4e8;
  }

  .toc-list-item {
    margin: 0;
    padding: 0;
    position: relative;
    list-style: none;
  }

  /* 左侧竖线上的圆点 */
  .toc-root > .toc-list-item::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #d1d9e0;
    border: 2px solid #ffffff;
    z-index: 1;
  }

  .toc-nested > .toc-list-item::before {
    content: '';
    position: absolute;
    left: -19px;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #d1d9e0;
    border: 2px solid #ffffff;
    z-index: 1;
  }

  .toc-item {
    display: block;
    padding: 8px 12px;
    font-size: 14px;
    color: #8590a6; /* 默认灰色，类似知乎 */
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s;
    line-height: 1.5;
    position: relative;
  }

  /* 覆盖浏览器默认的 visited 样式，保证始终是自定义的灰/蓝色 */
  .toc-item:link,
  .toc-item:visited {
    color: #8590a6;
  }

  /* 不同层级的样式 */
  .toc-level-2 .toc-item {
    font-weight: 500;
    font-size: 14px;
    color: #8590a6; /* 默认灰色 */
    padding-left: 0;
  }

  .toc-level-3 .toc-item {
    font-weight: 400;
    font-size: 13px;
    color: #8590a6; /* 默认灰色 */
    padding-left: 4px;
  }

  .toc-level-4 .toc-item {
    font-weight: 400;
    font-size: 12px;
    color: #8590a6; /* 默认灰色 */
    padding-left: 8px;
  }

  /* 悬停时保持灰色，不改变颜色 */
  .toc-item:hover {
    background-color: #f6f8fa;
    color: #8590a6; /* 保持灰色 */
  }

  /* 激活状态：蓝色，类似知乎 */
  .toc-item.active {
    background-color: transparent;
    color: #1890ff; /* 蓝色，类似知乎 */
    font-weight: 500;
  }

  .toc-item.active:link,
  .toc-item.active:visited {
    color: #1890ff;
  }

  .toc-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 16px;
    background-color: #1890ff; /* 蓝色指示条，匹配文字颜色 */
    border-radius: 0 2px 2px 0;
  }

  /* 移动端隐藏目录 */
  @media (max-width: 1024px) {
    .toc-container {
      display: none;
    }
  }

  /* 滚动条样式 */
  .toc-container::-webkit-scrollbar {
    width: 6px;
  }

  .toc-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc-container::-webkit-scrollbar-thumb {
    background: #d1d9e0;
    border-radius: 3px;
  }

  .toc-container::-webkit-scrollbar-thumb:hover {
    background: #a8b2bc;
  }
</style>

