---
import { PIE_EMPTY_DONUT_PATH, type CollectionPieItem } from "../lib/statistics-build";
import { getSupabaseClientConfig } from "../lib/visitor-env";

interface Props {
  totalPosts: number;
  pieItems: CollectionPieItem[];
  perArticleViewRows: { title: string; href: string; getUrl: string; pathKey: string }[];
  countStatsGetUrls: { site: string };
  /** 构建期算好的全站正文字数，避免把全站 `body` 注入客户端 */
  totalWordCount: number;
  /** 最新文章日期（ISO） */
  lastPostDateIso: string | null;
  siteStartDate: string;
  /** 已配置 Supabase 访客表时用库内 `page_path` 聚合，否则用 CountAPI */
  articleViewsSource?: "countapi" | "supabase";
}

const {
  totalPosts,
  pieItems,
  perArticleViewRows,
  countStatsGetUrls,
  totalWordCount: serverTotalWordCount,
  lastPostDateIso: serverLastPostDateIso,
  siteStartDate: clientSiteStartDate,
  articleViewsSource: articleViewsSourceProp = "countapi",
} = Astro.props;
const articleViewsSource = articleViewsSourceProp;
const supabaseClientConfig = getSupabaseClientConfig();
---

<section class="content-section about-statistics-wrap stat-scope">
  <h2 class="about-h2">Statistics</h2>
  <div class="stat-dashboard" aria-label="Site statistics control panel">
    <div class="stat-dashboard__rim">
      <div class="stat-dashboard__kpi">
        <div class="stat-kpi">
          <span class="stat-kpi__label">Days online</span>
          <span class="stat-kpi__value" id="days-online">-</span>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__label">Last update</span>
          <span class="stat-kpi__value stat-kpi__value--text" id="last-updated">-</span>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__label">Site page views</span>
          <span class="stat-kpi__value" id="stat-site-views">-</span>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__label">Word count</span>
          <span class="stat-kpi__value" id="total-words">-</span>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__label">Total article views</span>
          <span class="stat-kpi__value" id="stat-article-views-sum">—</span>
        </div>
      </div>

      <div class="stat-dashboard__row stat-dashboard__row--split">
        <div class="stat-panel stat-panel--ring">
          <div class="stat-panel__head">
            <span class="stat-panel__title">Posts by collection</span>
          </div>
          <div class="stat-pie-wrap">
            <div class="stat-pie" aria-label="Posts by collection, donut chart">
              <svg class="stat-pie__svg" viewBox="0 0 200 200" aria-hidden="true">
                {
                  pieItems.length > 0
                    ? pieItems.map((it) => {
                        const pct =
                          totalPosts > 0
                            ? ((it.count / totalPosts) * 100).toFixed(2)
                            : "0.00";
                        const line = `${it.label}：${it.count}（${pct}%）`;
                        return (
                          <path
                            class="stat-pie__seg"
                            d={it.slicePath}
                            fill={it.color}
                            data-pie-label={it.label}
                            data-pie-count={String(it.count)}
                            data-pie-pct={pct}
                            title={line}
                          >
                            <title>{line}</title>
                          </path>
                        );
                      })
                    : (
                        <path
                          class="stat-pie__seg stat-pie__seg--empty"
                          d={PIE_EMPTY_DONUT_PATH}
                          fill="hsl(210 18% 48%)"
                        />
                      )
                }
              </svg>
              <div class="stat-pie__hole" aria-hidden="true">
                <div class="stat-pie__center-val">{totalPosts}</div>
                <div class="stat-pie__center-lbl">posts</div>
              </div>
            </div>
            <ul class="stat-legend" aria-label="Collection legend">
              {pieItems.map((it) => (
                <li class="stat-legend__item">
                  <span class="stat-legend__sw" style={`background: ${it.color}`}></span>
                  <span class="stat-legend__name">{it.label}</span>
                  <span class="stat-legend__n">{it.count}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="stat-panel stat-panel--bars">
        <div class="stat-panel__head">
          <span class="stat-panel__title">Article views by post</span>
        </div>
        <div class="stat-bar-chart" id="stat-article-views-bars">
          <p class="stat-bar-load">Loading per-post view counts…</p>
        </div>
        <div class="stat-bar-actions">
          <button
            id="stat-article-views-toggle"
            class="stat-bar-toggle"
            type="button"
            hidden
            aria-controls="stat-article-views-bars"
            aria-expanded="false"
          >
            Expand
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .stat-scope {
    /* 与 about 页一致：数字改为站点正文 sans 字体栈 */
    --stat-number-font: var(
      --font-family-sans-serif,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      "Helvetica Neue",
      Arial,
      "Noto Sans",
      "Liberation Sans",
      sans-serif
    );
  }

  .stat-scope .about-h2 {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 14px;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .stat-scope .stat-dashboard {
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--text-link) 18%, var(--border-color));
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--bg-tertiary) 88%, #0a0e14) 0%,
      var(--bg-secondary) 45%,
      var(--bg-tertiary) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 8px 28px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .stat-scope .stat-dashboard__rim {
    padding: 18px 20px 22px;
  }

  .stat-scope .stat-dashboard__kpi {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 10px 14px;
    margin-bottom: 20px;
  }

  .stat-scope .stat-kpi {
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 10px 12px 12px;
    background: color-mix(in srgb, var(--bg-primary) 55%, transparent);
    font-family: var(--stat-number-font);
  }

  .stat-scope .stat-kpi__label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 6px;
  }

  .stat-scope .stat-kpi__value {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .stat-scope .stat-kpi__value--text {
    font-size: 0.88rem;
    font-weight: 600;
  }

  .stat-scope .stat-panel {
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 16px 16px 18px;
    background: var(--bg-primary);
  }

  .stat-scope .stat-panel + .stat-panel {
    margin-top: 16px;
  }

  .stat-scope .stat-panel__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .stat-scope .stat-panel__title {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .stat-scope .stat-panel__sub {
    margin: 0 0 12px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .stat-scope .stat-pie-wrap {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px 32px;
    overflow: visible;
  }

  @media (max-width: 520px) {
    .stat-scope .stat-pie-wrap {
      flex-direction: column;
      align-items: center;
    }
  }

  .stat-scope .stat-pie {
    position: relative;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--bg-primary);
    margin: 10px;
    overflow: visible;
    z-index: 0;
  }

  .stat-scope .stat-pie__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
    /* `pointer-events: none` 在部分 WebKit/Chrome 上会导致子 path 命中区域异常，改为 all 后仍只有扇区可点 */
    pointer-events: all;
  }

  .stat-scope .stat-pie__seg {
    pointer-events: auto;
    stroke: none;
    filter: brightness(1);
    transition: filter 0.22s ease, opacity 0.22s ease;
    cursor: pointer;
  }

  .stat-scope .stat-pie__seg:hover {
    /* 不再缩放 path：避免边界命中变化导致 hover 抖动 */
    filter: brightness(1.08) drop-shadow(0 2px 6px rgba(0, 0, 0, 0.18));
  }

  .stat-scope .stat-pie__seg--empty {
    cursor: default;
  }

  .stat-scope .stat-pie__seg--empty:hover {
    filter: brightness(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-scope .stat-pie__seg {
      transition: none;
    }
    .stat-scope .stat-pie__seg:hover {
      filter: brightness(1.04);
    }
  }

  .stat-scope .stat-pie__hole {
    position: absolute;
    inset: 22%;
    z-index: 1;
    border-radius: 50%;
    background: var(--bg-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    /* 去掉内圈「圆环」线；不挡环上扇形的鼠标事件 */
    border: none;
    box-shadow: none;
    outline: none;
    pointer-events: none;
  }

  .stat-scope .stat-pie__center-val {
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.1;
    font-family: var(--stat-number-font);
  }

  .stat-scope .stat-pie__center-lbl {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .stat-scope .stat-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 0 1 auto;
    min-width: 0;
    max-width: min(100%, 18rem);
    align-self: center;
  }

  @media (max-width: 520px) {
    .stat-scope .stat-legend {
      max-width: 100%;
      width: 100%;
    }
  }

  .stat-scope .stat-legend__item {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: 6px 10px;
    font-size: 0.86rem;
    margin: 6px 0;
    color: var(--text-primary);
  }

  .stat-scope .stat-legend__sw {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .stat-scope .stat-legend__name {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stat-scope .stat-legend__n {
    font-weight: 700;
    font-family: var(--stat-number-font);
    color: var(--text-secondary);
  }

  .stat-scope .stat-bar-load {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 8px 0 0;
  }

  .stat-scope .stat-bar-chart {
    max-height: 320px;
    overflow: auto;
    padding-right: 2px;
  }

  .stat-scope .stat-bar-actions {
    margin-top: 4px;
    display: flex;
    justify-content: flex-start;
  }

  .stat-scope .stat-bar-toggle {
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: color-mix(in srgb, var(--bg-secondary) 86%, transparent);
    color: rgba(226, 232, 240, 0.92);
    padding: 2px 8px;
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    border-radius: 999px;
    line-height: 1.35;
    cursor: pointer;
  }

  .stat-scope .stat-bar-toggle:hover {
    border-color: rgba(148, 163, 184, 0.55);
    color: #f8fafc;
  }

  .stat-scope .stat-bar-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2.2fr) 48px;
    gap: 8px 10px;
    align-items: center;
    margin: 0 0 8px;
    font-size: 0.82rem;
  }

  .stat-scope .stat-bar-label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-link);
    text-decoration: none;
  }

  .stat-scope .stat-bar-label:hover {
    text-decoration: underline;
  }

  .stat-scope .stat-bar-track {
    height: 10px;
    border-radius: 6px;
    background: transparent;
    overflow: visible;
    box-shadow: none;
  }

  .stat-scope .stat-bar-fill {
    height: 100%;
    width: 0;
    /* Match nav: accent + nav-bg blend */
    background: linear-gradient(
      90deg,
      var(--fluid-link-hover-color, #30a9de),
      color-mix(
        in srgb,
        var(--nav-bg, #2f4154) 55%,
        var(--fluid-link-hover-color, #30a9de) 45%
      )
    );
    border-radius: 6px;
    transition: width 0.35s ease;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .stat-scope .stat-bar-n {
    text-align: right;
    font-weight: 700;
    font-family: var(--stat-number-font);
    color: var(--text-primary);
  }
</style>

<script
  define:vars={{
    serverTotalWordCount,
    serverLastPostDateIso,
    siteStartDate: clientSiteStartDate,
    countStatsGetUrls,
    perArticleViewRows,
    articleViewsSource,
    supabaseClientConfig,
  }}
>
  (function () {
    "use strict";
    function normalizeArticlePathForStats(href) {
      if (!href) return "/";
      const p = String(href).split("?")[0].split("#")[0];
      const withSlash = p.startsWith("/") ? p : `/${p}`;
      let decoded = withSlash;
      try {
        decoded = decodeURI(withSlash);
      } catch {
        decoded = withSlash;
      }
      return decoded.replace(/\/+$/, "") || "/";
    }

    function updateStatistics() {
      try {
        const n =
          typeof serverTotalWordCount === "number" && !Number.isNaN(serverTotalWordCount)
            ? serverTotalWordCount
            : 0;
        const totalWordsFormatted = n >= 10000 ? `${(n / 10000).toFixed(1)}w` : String(n);
        const totalWordsEl = document.getElementById("total-words");
        if (totalWordsEl) totalWordsEl.textContent = totalWordsFormatted;

        if (serverLastPostDateIso) {
          const last = new Date(serverLastPostDateIso);
          if (!isNaN(last.getTime())) {
            const months = [
              "Jan", "Feb", "Mar", "Apr", "May", "Jun",
              "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
            ];
            const lastUpdatedFormatted = `${months[last.getMonth()]} ${last.getDate()}, ${last.getFullYear()}`;
            const lastUpdatedEl = document.getElementById("last-updated");
            if (lastUpdatedEl) lastUpdatedEl.textContent = lastUpdatedFormatted;
          }
        }
        if (siteStartDate) {
          const startDate = new Date(siteStartDate);
          const today = new Date();
          if (!isNaN(startDate.getTime())) {
            const daysOnline = Math.floor(
              (today.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)
            );
            const daysOnlineEl = document.getElementById("days-online");
            if (daysOnlineEl) daysOnlineEl.textContent = String(daysOnline);
          }
        }
      } catch (e) {
        console.error("Error updating statistics:", e);
      }
    }

    async function loadCountStats() {
      const siteEl = document.getElementById("stat-site-views");
      if (!siteEl) return;
      const mark = () => {
        siteEl.textContent = "—";
      };
      if (typeof countStatsGetUrls === "undefined" || !countStatsGetUrls || !countStatsGetUrls.site) {
        mark();
        return;
      }
      const setNum = (n) => {
        siteEl.textContent = typeof n === "number" && !Number.isNaN(n) ? String(n) : "—";
      };
      try {
        const ctrl = new AbortController();
        const t = setTimeout(() => ctrl.abort(), 10000);
        const a = await fetch(String(countStatsGetUrls.site), {
          mode: "cors",
          cache: "no-store",
          signal: ctrl.signal,
        })
          .then((r) => r.json())
          .catch(() => null)
          .finally(() => clearTimeout(t));
        setNum(a && typeof a.value === "number" ? a.value : null);
      } catch (e) {
        mark();
      }
    }

    function fetchCountValue(url) {
      return new Promise((resolve) => {
        const ctrl = new AbortController();
        const tid = setTimeout(() => {
          ctrl.abort();
          resolve(0);
        }, 10000);
        fetch(String(url), { mode: "cors", cache: "no-store", signal: ctrl.signal })
          .then((r) => (r.ok ? r.json() : null))
          .then((j) => (j && typeof j.value === "number" ? j.value : 0))
          .then((v) => {
            clearTimeout(tid);
            resolve(v);
          })
          .catch(() => {
            clearTimeout(tid);
            resolve(0);
          });
      });
    }

    const BAR_COLLAPSED_LIMIT = 5;
    let articleBarsExpanded = false;
    let articleBarRows = [];

    function updateArticleToggleUI(host) {
      const btn = document.getElementById("stat-article-views-toggle");
      if (!btn) return;
      const hasMore = articleBarRows.length > BAR_COLLAPSED_LIMIT;
      btn.hidden = !hasMore;
      if (!hasMore) return;
      btn.textContent = articleBarsExpanded
        ? "Collapse"
        : `Expand (${articleBarRows.length})`;
      btn.setAttribute("aria-expanded", articleBarsExpanded ? "true" : "false");
      btn.onclick = () => {
        articleBarsExpanded = !articleBarsExpanded;
        renderArticleBarRows(host);
      };
    }

    function renderArticleBarRows(host) {
      const rows = articleBarRows;
      const visible = articleBarsExpanded ? rows : rows.slice(0, BAR_COLLAPSED_LIMIT);
      const max = rows.length ? Math.max(1, ...rows.map((x) => x.v)) : 1;
      const frag = document.createDocumentFragment();
      visible.forEach((row) => {
        const wrap = document.createElement("div");
        wrap.className = "stat-bar-row";
        const a = document.createElement("a");
        a.className = "stat-bar-label";
        a.href = row.href;
        a.textContent = row.title;
        a.title = row.title;
        const tr = document.createElement("div");
        tr.className = "stat-bar-track";
        const fill = document.createElement("div");
        fill.className = "stat-bar-fill";
        fill.style.width = `${(row.v / max) * 100}%`;
        tr.appendChild(fill);
        const n = document.createElement("span");
        n.className = "stat-bar-n";
        n.textContent = String(row.v);
        wrap.appendChild(a);
        wrap.appendChild(tr);
        wrap.appendChild(n);
        frag.appendChild(wrap);
      });
      host.textContent = "";
      host.appendChild(frag);
      updateArticleToggleUI(host);
    }

    function applyArticleBarRows(host, sumEl, withVals) {
      const sorted = [...withVals].sort((a, b) => b.v - a.v);
      articleBarRows = sorted;
      let sum = 0;
      sorted.forEach((x) => {
        sum += x.v;
      });
      renderArticleBarRows(host);
      if (sumEl) sumEl.textContent = String(sum);
    }

    async function loadPerArticleBarChart() {
      const host = document.getElementById("stat-article-views-bars");
      const sumEl = document.getElementById("stat-article-views-sum");
      if (!host) return;
      const rows = Array.isArray(perArticleViewRows) ? perArticleViewRows : [];
      if (rows.length === 0) {
        host.innerHTML = '<p class="stat-bar-load">No posts</p>';
        if (sumEl) sumEl.textContent = "0";
        return;
      }

      if (articleViewsSource === "supabase") {
        const cfg =
          supabaseClientConfig &&
          typeof supabaseClientConfig === "object" &&
          typeof supabaseClientConfig.url === "string" &&
          typeof supabaseClientConfig.anonKey === "string"
            ? supabaseClientConfig
            : null;
        if (cfg) {
          const k = String(cfg.anonKey || "").trim();
          if (k.startsWith("sb_secret_")) {
            console.warn(
              "[stat] Supabase：当前为 Secret 公钥，无法用于网页；M02 将回退 CountAPI。"
            );
          } else {
            try {
              const endpoint = String(cfg.url).replace(/\/+$/, "") +
                "/rest/v1/blog_visit_path_stats?select=page_path,views";
              const ctrl = new AbortController();
              const tid = setTimeout(() => ctrl.abort(), 12000);
              const res = await fetch(endpoint, {
                method: "GET",
                headers: {
                  apikey: cfg.anonKey,
                  Authorization: `Bearer ${cfg.anonKey}`,
                  Accept: "application/json",
                },
                signal: ctrl.signal,
              }).finally(() => clearTimeout(tid));
              if (res.ok) {
                const data = await res.json();
                const map = new Map();
                for (const r of data) {
                  const p = normalizeArticlePathForStats(String(r.page_path || ""));
                  const n = Number(r.views);
                  const add = Number.isFinite(n) ? n : 0;
                  map.set(p, (map.get(p) || 0) + add);
                }
                const withVals = rows.map((r) => {
                  const k2 = r.pathKey || normalizeArticlePathForStats(r.href);
                  const v = map.get(k2) ?? 0;
                  return { ...r, v };
                });
                const totalFromPath = withVals.reduce((acc, item) => acc + (item.v || 0), 0);
                if (totalFromPath > 0) {
                  applyArticleBarRows(host, sumEl, withVals);
                  return;
                }
                console.warn(
                  "[stat] blog_visit_path_stats is empty/all-zero, fallback to countapi"
                );
              } else {
                console.warn("[stat] blog_visit_path_stats HTTP failed:", res.status);
              }
            } catch (e) {
              console.warn("[stat] blog_visit_path_stats failed, falling back to countapi", e);
            }
          }
        }
      }

      const CHUNK = 8;
      const withVals = [];
      for (let i = 0; i < rows.length; i += CHUNK) {
        const part = rows.slice(i, i + CHUNK);
        const vals = await Promise.all(
          part.map((r) => fetchCountValue(r.getUrl).then((v) => ({ ...r, v })))
        );
        withVals.push.apply(withVals, vals);
      }
      applyArticleBarRows(host, sumEl, withVals);
    }

    function init() {
      try {
        updateStatistics();
      } catch (e) {
        console.error("updateStatistics() error:", e);
      }
      try {
        loadCountStats();
      } catch (e) {
        console.error("loadCountStats() error:", e);
      }
      try {
        loadPerArticleBarChart();
      } catch (e) {
        console.error("loadPerArticleBarChart() error:", e);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      setTimeout(init, 100);
    }

    setInterval(() => {
      updateStatistics();
      loadCountStats();
