---
import { PIE_EMPTY_DONUT_PATH, type CollectionPieItem } from "../lib/statistics-build";
import { getSupabaseClientConfig } from "../lib/visitor-env";

interface Props {
  totalPosts: number;
  pieItems: CollectionPieItem[];
  perArticleViewRows: { title: string; href: string; getUrl: string; pathKey: string }[];
  countStatsGetUrls: { site: string };
  /** 构建期算好的全站正文字数，避免把全站 `body` 注入客户端 */
  totalWordCount: number;
  /** 最新文章日期（ISO） */
  lastPostDateIso: string | null;
  siteStartDate: string;
  /** 已配置 Supabase 访客表时用库内 `page_path` 聚合，否则用 CountAPI */
  articleViewsSource?: "countapi" | "supabase";
}

const {
  totalPosts,
  pieItems,
  perArticleViewRows,
  countStatsGetUrls,
  totalWordCount: serverTotalWordCount,
  lastPostDateIso: serverLastPostDateIso,
  siteStartDate: clientSiteStartDate,
  articleViewsSource: articleViewsSourceProp = "countapi",
} = Astro.props;
const articleViewsSource = articleViewsSourceProp;
const supabaseClientConfig = getSupabaseClientConfig();
const walineServerUrl = String(import.meta.env.PUBLIC_WALINE_SERVER_URL ?? "").trim();
---

<section class="content-section about-statistics-wrap stat-scope">
  <h2 class="about-h2">Statistics</h2>
  <div class="stat-dashboard" aria-label="Site statistics control panel">
    <div class="stat-dashboard__rim">
      <div class="stat-dashboard__kpi">
        <div class="stat-kpi">
          <span class="stat-kpi__glyph stat-kpi__glyph--sky" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3.5" y="5" width="17" height="15" rx="2"></rect>
              <path d="M8 3.5v3M16 3.5v3M3.5 10.5h17"></path>
            </svg>
          </span>
          <div class="stat-kpi__body">
            <span class="stat-kpi__label">Days online</span>
            <span class="stat-kpi__value" id="days-online">-</span>
          </div>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__glyph stat-kpi__glyph--violet" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="7.5"></circle>
              <path d="M12 8.25v4l2.75 1.5"></path>
            </svg>
          </span>
          <div class="stat-kpi__body">
            <span class="stat-kpi__label">Last update</span>
            <span class="stat-kpi__value stat-kpi__value--text" id="last-updated">-</span>
          </div>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__glyph stat-kpi__glyph--cyan" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2.25 12s3.5-6 9.75-6 9.75 6 9.75 6-3.5 6-9.75 6S2.25 12 2.25 12z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </span>
          <div class="stat-kpi__body">
            <span class="stat-kpi__label">Site page views</span>
            <span class="stat-kpi__value" id="stat-site-views">-</span>
          </div>
        </div>
        <div class="stat-kpi">
          <span class="stat-kpi__glyph stat-kpi__glyph--emerald" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8.25 4.5h-3a1.5 1.5 0 0 0-1.5 1.5v13.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-9"></path>
              <path d="M10.5 13.5 21 3M15 3h6v6"></path>
            </svg>
          </span>
          <div class="stat-kpi__body">
            <span class="stat-kpi__label">Word count</span>
            <span class="stat-kpi__value" id="total-words">-</span>
          </div>
        </div>
        <div class="stat-kpi stat-kpi--span">
          <span class="stat-kpi__glyph stat-kpi__glyph--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5V6a1.5 1.5 0 0 1 1.5-1.5h9L20 10v9.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 4 19.5z"></path>
              <path d="M14.25 4.5V9H19"></path>
              <path d="M8 13h8M8 16.5h5"></path>
            </svg>
          </span>
          <div class="stat-kpi__body">
            <span class="stat-kpi__label">Total article views</span>
            <span class="stat-kpi__value" id="stat-article-views-sum">—</span>
          </div>
        </div>
      </div>

      <div class="stat-dashboard__row stat-dashboard__row--split">
        <div class="stat-panel stat-panel--ring">
          <div class="stat-panel__head">
            <span class="stat-panel__title">Posts by collection</span>
          </div>
          <div class="stat-pie-wrap">
            <div class="stat-pie" aria-label="Posts by collection, donut chart">
              <svg class="stat-pie__svg" viewBox="0 0 200 200" aria-hidden="true">
                {
                  pieItems.length > 0
                    ? pieItems.map((it) => {
                        const pct =
                          totalPosts > 0
                            ? ((it.count / totalPosts) * 100).toFixed(2)
                            : "0.00";
                        const line = `${it.label}：${it.count}（${pct}%）`;
                        return (
                          <path
                            class="stat-pie__seg"
                            d={it.slicePath}
                            fill={it.color}
                            data-pie-label={it.label}
                            data-pie-count={String(it.count)}
                            data-pie-pct={pct}
                            title={line}
                          >
                            <title>{line}</title>
                          </path>
                        );
                      })
                    : (
                        <path
                          class="stat-pie__seg stat-pie__seg--empty"
                          d={PIE_EMPTY_DONUT_PATH}
                          fill="hsl(210 18% 48%)"
                        />
                      )
                }
              </svg>
              <div class="stat-pie__hole" aria-hidden="true">
                <div class="stat-pie__center-val">{totalPosts}</div>
                <div class="stat-pie__center-lbl">posts</div>
              </div>
            </div>
            <ul class="stat-legend" aria-label="Collection legend">
              {pieItems.map((it) => (
                <li class="stat-legend__item">
                  <span class="stat-legend__sw" style={`background: ${it.color}`}></span>
                  <span class="stat-legend__name">{it.label}</span>
                  <span class="stat-legend__n">{it.count}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="stat-panel stat-panel--bars">
        <div class="stat-bar-chart" id="stat-article-views-bars">
          <p class="stat-bar-load">Loading per-post view counts…</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .stat-scope {
    /* 与 about 页一致：数字改为站点正文 sans 字体栈 */
    --stat-number-font: var(
      --font-family-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      "Helvetica Neue",
      Arial,
      "Noto Sans",
      "PingFang SC",
      "Microsoft YaHei",
      sans-serif
    );
  }

  .stat-scope .about-h2 {
    font-size: 1.28rem;
    font-weight: 600;
    margin: 0 0 14px;
    color: var(--text-primary);
    line-height: 1.28;
    letter-spacing: -0.015em;
  }

  .stat-scope .stat-dashboard {
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--text-link) 22%, var(--border-color));
    background: color-mix(in srgb, var(--bg-secondary) 48%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.055),
      0 12px 36px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  .stat-scope .stat-dashboard__rim {
    padding: 18px 20px 22px;
  }

  /* 最小列宽约等于「图标 + 间距 + 标签单行」，避免左侧窄栏里强行四列挤成竖排字 */
  .stat-scope .stat-dashboard__kpi {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 168px), 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-scope .stat-kpi--span {
    grid-column: 1 / -1;
  }

  .stat-scope .stat-kpi {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    min-width: 0;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 12px 14px 14px;
    background: color-mix(in srgb, var(--bg-primary) 32%, transparent);
    font-family: var(--stat-number-font);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 4px 14px rgba(0, 0, 0, 0.06);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .stat-scope .stat-kpi:hover {
    border-color: color-mix(in srgb, var(--text-link) 35%, var(--border-color));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 8px 22px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-scope .stat-kpi {
      transition: none;
    }

    .stat-scope .stat-kpi:hover {
      transform: none;
    }
  }

  .stat-scope .stat-kpi__glyph {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 11px;
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  .stat-scope .stat-kpi__glyph svg {
    width: 19px;
    height: 19px;
  }

  .stat-scope .stat-kpi__glyph--sky {
    background: linear-gradient(145deg, rgba(56, 189, 248, 0.35), rgba(14, 165, 233, 0.14));
  }

  .stat-scope .stat-kpi__glyph--violet {
    background: linear-gradient(145deg, rgba(167, 139, 250, 0.38), rgba(139, 92, 246, 0.16));
  }

  .stat-scope .stat-kpi__glyph--cyan {
    background: linear-gradient(145deg, rgba(34, 211, 238, 0.32), rgba(6, 182, 212, 0.14));
  }

  .stat-scope .stat-kpi__glyph--emerald {
    background: linear-gradient(145deg, rgba(52, 211, 153, 0.34), rgba(16, 185, 129, 0.14));
  }

  .stat-scope .stat-kpi__glyph--amber {
    background: linear-gradient(145deg, rgba(251, 191, 36, 0.36), rgba(245, 158, 11, 0.14));
  }

  .stat-scope .stat-kpi__body {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-scope .stat-kpi__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.065em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-secondary) 92%, transparent);
    line-height: 1.25;
    word-break: normal;
    overflow-wrap: break-word;
  }

  .stat-scope .stat-kpi__value {
    font-size: 1.375rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
    color: color-mix(in srgb, var(--text-primary) 97%, #0f172a);
    line-height: 1.14;
    letter-spacing: -0.022em;
    word-break: normal;
    overflow-wrap: break-word;
  }

  .stat-scope .stat-kpi__value--text {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.012em;
    color: color-mix(in srgb, var(--text-primary) 88%, var(--text-secondary));
    line-height: 1.35;
  }

  .stat-scope .stat-panel {
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 16px 16px 18px;
    background: color-mix(in srgb, var(--bg-primary) 35%, transparent);
  }

  .stat-scope .stat-panel + .stat-panel {
    margin-top: 16px;
  }

  .stat-scope .stat-panel__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .stat-scope .stat-panel__title {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-secondary) 93%, transparent);
  }

  .stat-scope .stat-panel__sub {
    margin: 0 0 12px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .stat-scope .stat-pie-wrap {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px 32px;
    overflow: visible;
  }

  @media (max-width: 520px) {
    .stat-scope .stat-pie-wrap {
      flex-direction: column;
      align-items: center;
    }
  }

  .stat-scope .stat-pie {
    position: relative;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--bg-primary);
    margin: 10px;
    overflow: visible;
    z-index: 0;
  }

  .stat-scope .stat-pie__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
    /* `pointer-events: none` 在部分 WebKit/Chrome 上会导致子 path 命中区域异常，改为 all 后仍只有扇区可点 */
    pointer-events: all;
  }

  .stat-scope .stat-pie__seg {
    pointer-events: auto;
    stroke: none;
    filter: brightness(1);
    opacity: 0.96;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(1);
    transition:
      transform 0.22s ease,
      filter 0.22s ease,
      opacity 0.22s ease,
      stroke 0.22s ease,
      stroke-width 0.22s ease;
    cursor: pointer;
  }

  .stat-scope .stat-pie:hover .stat-pie__seg:not(.stat-pie__seg--empty) {
    opacity: 0.58;
  }

  .stat-scope .stat-pie__seg:hover,
  .stat-scope .stat-pie__seg:focus-visible {
    /* 放大强调 + 高亮描边，接近“扇区凸显”效果 */
    transform: scale(1.08);
    filter: brightness(1.2) saturate(1.15) drop-shadow(0 3px 8px rgba(0, 0, 0, 0.28));
    opacity: 1 !important;
    stroke: rgba(255, 255, 255, 0.55);
    stroke-width: 1.4;
    outline: none;
  }

  .stat-scope .stat-pie__seg--empty {
    cursor: default;
  }

  .stat-scope .stat-pie__seg--empty:hover {
    filter: brightness(1);
    stroke: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-scope .stat-pie__seg {
      transition: none;
    }
    .stat-scope .stat-pie__seg:hover {
      transform: scale(1.04);
      filter: brightness(1.14);
    }
  }

  .stat-scope .stat-pie__hole {
    position: absolute;
    inset: 22%;
    z-index: 1;
    border-radius: 50%;
    background: var(--bg-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    /* 去掉内圈「圆环」线；不挡环上扇形的鼠标事件 */
    border: none;
    box-shadow: none;
    outline: none;
    pointer-events: none;
  }

  .stat-scope .stat-pie__center-val {
    font-size: 1.62rem;
    font-weight: 800;
    font-feature-settings: "tnum" 1, "lnum" 1;
    letter-spacing: -0.03em;
    color: color-mix(in srgb, var(--text-primary) 98%, #020617);
    line-height: 1.1;
    font-family: var(--stat-number-font);
  }

  .stat-scope .stat-pie__center-lbl {
    font-size: 0.6375rem;
    font-weight: 500;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-secondary) 90%, transparent);
  }

  .stat-scope .stat-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 0 1 auto;
    min-width: 0;
    max-width: min(100%, 18rem);
    align-self: center;
  }

  @media (max-width: 520px) {
    .stat-scope .stat-legend {
      max-width: 100%;
      width: 100%;
    }
  }

  .stat-scope .stat-legend__item {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: 6px 10px;
    font-size: 0.875rem;
    margin: 6px 0;
    color: color-mix(in srgb, var(--text-primary) 96%, var(--text-secondary));
    font-weight: 500;
  }

  .stat-scope .stat-legend__sw {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .stat-scope .stat-legend__name {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stat-scope .stat-legend__n {
    font-weight: 600;
    font-family: var(--stat-number-font);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
    color: color-mix(in srgb, var(--text-secondary) 94%, transparent);
  }

  .stat-scope .stat-bar-load {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 8px 0 0;
  }

  .stat-scope .stat-bar-chart {
    max-height: none;
    overflow: visible;
    padding-right: 2px;
  }

  .stat-scope .stat-rank-wrap {
    display: grid;
    gap: 14px;
  }

  .stat-scope .stat-rank-block {
    display: grid;
    gap: 6px;
  }

  .stat-scope .stat-rank-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--text-primary) 97%, var(--text-secondary));
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .stat-scope .stat-rank-list {
    margin: 0;
    padding-left: 1.45rem;
    display: grid;
    gap: 4px;
  }

  .stat-scope .stat-rank-item {
    color: color-mix(in srgb, var(--text-primary) 82%, var(--text-secondary));
    line-height: 1.45;
    font-size: 0.84375rem;
    font-weight: 400;
  }

  .stat-scope .stat-rank-link {
    color: inherit;
    text-decoration: none;
  }

  .stat-scope .stat-rank-link:hover {
    color: color-mix(in srgb, var(--text-primary) 94%, var(--text-secondary));
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .stat-scope .stat-rank-num {
    color: color-mix(in srgb, var(--text-primary) 96%, transparent);
    font-family: var(--stat-number-font);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    margin-left: 4px;
  }

  .stat-scope .stat-rank-empty {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.82rem;
  }

  .stat-scope .stat-comment-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .stat-scope .stat-comment-item {
    margin: 0;
    padding: 0;
    line-height: 1.45;
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--text-primary) 82%, var(--text-secondary));
    font-weight: 400;
  }

  .stat-scope .stat-comment-link {
    color: inherit;
    text-decoration: none;
  }

  .stat-scope .stat-comment-link:hover {
    color: color-mix(in srgb, var(--text-primary) 94%, var(--text-secondary));
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .stat-scope .stat-comment-author {
    color: color-mix(in srgb, var(--text-primary) 96%, transparent);
    font-weight: 600;
    margin-right: 6px;
  }

  .stat-scope .stat-comment-time {
    color: var(--text-secondary);
    font-size: 0.74rem;
    margin-left: 6px;
  }
</style>

<script
  define:vars={{
    serverTotalWordCount,
    serverLastPostDateIso,
    siteStartDate: clientSiteStartDate,
    countStatsGetUrls,
    perArticleViewRows,
    articleViewsSource,
    supabaseClientConfig,
    walineServerUrl,
  }}
>
  (function () {
    "use strict";
    function normalizeArticlePathForStats(href) {
      if (!href) return "/";
      const p = String(href).split("?")[0].split("#")[0];
      const withSlash = p.startsWith("/") ? p : `/${p}`;
      let decoded = withSlash;
      try {
        decoded = decodeURI(withSlash);
      } catch {
        decoded = withSlash;
      }
      return decoded.replace(/\/+$/, "") || "/";
    }

    /** 与 blog_visit_path_stats 的 page_path 对齐；尝试 encode 形式减少漏配 */
    function pathStatsViewsForArticle(map, pathKey) {
      if (!map || map.size === 0) return 0;
      const k = normalizeArticlePathForStats(pathKey);
      if (map.has(k)) return Number(map.get(k)) || 0;
      try {
        const enc = encodeURI(k);
        if (enc !== k && map.has(enc)) return Number(map.get(enc)) || 0;
      } catch (_) {
        /* ignore */
      }
      return 0;
    }

    function updateStatistics() {
      try {
        const n =
          typeof serverTotalWordCount === "number" && !Number.isNaN(serverTotalWordCount)
            ? serverTotalWordCount
            : 0;
        const totalWordsFormatted = n >= 10000 ? `${(n / 10000).toFixed(1)}w` : String(n);
        const totalWordsEl = document.getElementById("total-words");
        if (totalWordsEl) totalWordsEl.textContent = totalWordsFormatted;

        if (serverLastPostDateIso) {
          const last = new Date(serverLastPostDateIso);
          if (!isNaN(last.getTime())) {
            const months = [
              "Jan", "Feb", "Mar", "Apr", "May", "Jun",
              "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
            ];
            const lastUpdatedFormatted = `${months[last.getMonth()]} ${last.getDate()}, ${last.getFullYear()}`;
            const lastUpdatedEl = document.getElementById("last-updated");
            if (lastUpdatedEl) lastUpdatedEl.textContent = lastUpdatedFormatted;
          }
        }
        if (siteStartDate) {
          const startDate = new Date(siteStartDate);
          const today = new Date();
          if (!isNaN(startDate.getTime())) {
            const daysOnline = Math.floor(
              (today.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)
            );
            const daysOnlineEl = document.getElementById("days-online");
            if (daysOnlineEl) daysOnlineEl.textContent = String(daysOnline);
          }
        }
      } catch (e) {
        console.error("Error updating statistics:", e);
      }
    }

    async function loadCountStats() {
      const siteEl = document.getElementById("stat-site-views");
      if (!siteEl) return;
      const mark = () => {
        siteEl.textContent = "—";
      };
      const setNum = (n) => {
        siteEl.textContent = typeof n === "number" && !Number.isNaN(n) ? String(n) : "—";
      };
      const loadSiteViewsFromSupabase = async () => {
        const cfg =
          supabaseClientConfig &&
          typeof supabaseClientConfig === "object" &&
          typeof supabaseClientConfig.url === "string" &&
          typeof supabaseClientConfig.anonKey === "string"
            ? supabaseClientConfig
            : null;
        if (!cfg) return null;
        const k = String(cfg.anonKey || "").trim();
        if (!k || k.startsWith("sb_secret_")) return null;
        try {
          const endpoint =
            String(cfg.url).replace(/\/+$/, "") +
            "/rest/v1/blog_visits?select=id&order=created_at.desc&limit=1";
          const ctrl = new AbortController();
          const tid = setTimeout(() => ctrl.abort(), 10000);
          const res = await fetch(endpoint, {
            method: "GET",
            headers: {
              apikey: cfg.anonKey,
              Authorization: `Bearer ${cfg.anonKey}`,
              Prefer: "count=exact",
              Range: "0-0",
            },
            signal: ctrl.signal,
          }).finally(() => clearTimeout(tid));
          if (!res.ok) return null;
          const cr = res.headers.get("content-range") || "";
          const m = cr.match(/\/(\d+)\s*$/);
          if (m) return Number(m[1]);
          return null;
        } catch {
          return null;
        }
      };
      if (typeof countStatsGetUrls === "undefined" || !countStatsGetUrls || !countStatsGetUrls.site) {
        const fallbackNum = await loadSiteViewsFromSupabase();
        if (typeof fallbackNum === "number") setNum(fallbackNum);
        else mark();
        return;
      }
      try {
        const ctrl = new AbortController();
        const t = setTimeout(() => ctrl.abort(), 10000);
        const a = await fetch(String(countStatsGetUrls.site), {
          mode: "cors",
          cache: "no-store",
          signal: ctrl.signal,
        })
          .then((r) => r.json())
          .catch(() => null)
          .finally(() => clearTimeout(t));
        const countapiNum = a && typeof a.value === "number" ? a.value : null;
        if (typeof countapiNum === "number") {
          setNum(countapiNum);
          return;
        }
        const fallbackNum = await loadSiteViewsFromSupabase();
        if (typeof fallbackNum === "number") setNum(fallbackNum);
        else mark();
      } catch (e) {
        const fallbackNum = await loadSiteViewsFromSupabase();
        if (typeof fallbackNum === "number") setNum(fallbackNum);
        else mark();
      }
    }

    function fetchCountValue(url) {
      return new Promise((resolve) => {
        const ctrl = new AbortController();
        const tid = setTimeout(() => {
          ctrl.abort();
          resolve(0);
        }, 10000);
        fetch(String(url), { mode: "cors", cache: "no-store", signal: ctrl.signal })
          .then((r) => (r.ok ? r.json() : null))
          .then((j) => (j && typeof j.value === "number" ? j.value : 0))
          .then((v) => {
            clearTimeout(tid);
            resolve(v);
          })
          .catch(() => {
            clearTimeout(tid);
            resolve(0);
          });
      });
    }

    function escapeHtml(s) {
      return String(s || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function renderRankList(rows, valueKey) {
      const top = [...rows]
        .sort((a, b) => {
          const av = Number(a[valueKey] ?? 0);
          const bv = Number(b[valueKey] ?? 0);
          return bv - av;
        })
        .filter((x) => Number(x[valueKey] ?? 0) > 0)
        .slice(0, 5);

      if (top.length === 0) {
        return `<p class="stat-rank-empty">暂无阅读量</p>`;
      }
      const items = top
        .map((x) => {
          const n = Number(x[valueKey] ?? 0);
          return `<li class="stat-rank-item"><a class="stat-rank-link" href="${escapeHtml(x.href)}" title="${escapeHtml(
            x.title
          )}">${escapeHtml(x.title)}</a><span class="stat-rank-num">(${n})</span></li>`;
        })
        .join("");
      return `<ol class="stat-rank-list">${items}</ol>`;
    }

    function toRecentCommentArray(raw) {
      if (Array.isArray(raw)) return raw;
      if (raw && typeof raw === "object") {
        if (Array.isArray(raw.data)) return raw.data;
        if (Array.isArray(raw.comments)) return raw.comments;
        if (Array.isArray(raw.result)) return raw.result;
      }
      return [];
    }

    function stripHtml(input) {
      return String(input || "").replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
    }

    function cutText(input, n) {
      const s = String(input || "");
      return s.length > n ? `${s.slice(0, n)}...` : s;
    }

    function fmtShortTime(value) {
      if (!value) return "";
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return "";
      return d.toLocaleString("zh-CN", {
        hour12: false,
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    async function fetchRecentComments(limit) {
      if (!walineServerUrl) return [];
      const base = String(walineServerUrl).replace(/\/+$/, "");
      const endpoints = [
        `${base}/comment?type=recent&count=${limit}`,
        `${base}/comment?type=recent&pageSize=${limit}`,
        `${base}/comment?type=recent&size=${limit}`,
      ];
      for (const endpoint of endpoints) {
        try {
          const ctrl = new AbortController();
          const tid = setTimeout(() => ctrl.abort(), 7000);
          const res = await fetch(endpoint, {
            method: "GET",
            mode: "cors",
            cache: "no-store",
            signal: ctrl.signal,
          }).finally(() => clearTimeout(tid));
          if (!res.ok) continue;
          const json = await res.json();
          const rows = toRecentCommentArray(json);
          if (!rows.length) continue;
          const normalized = rows
            .map((x) => {
              const author = x.nick || x.author || x.name || x.user?.nick || "匿名";
              const contentRaw = x.comment || x.content || x.text || "";
              const content = cutText(stripHtml(contentRaw), 72);
              const url = x.url || x.link || x.path || x.page?.url || "";
              const time =
                x.insertedAt || x.createdAt || x.created_at || x.updatedAt || x.time || x.date || "";
              return {
                author: String(author || "匿名"),
                content: String(content || ""),
                url: String(url || ""),
                time: fmtShortTime(time),
              };
            })
            .filter((x) => x.content)
            .slice(0, limit);
          if (normalized.length) return normalized;
        } catch {
          // try next endpoint
        }
      }
      return [];
    }

    function renderRecentCommentsList(items) {
      if (!items || items.length === 0) {
        return `<p class="stat-rank-empty">暂无最近评论</p>`;
      }
      const li = items
        .map((x) => {
          const href = x.url ? escapeHtml(String(x.url)) : "#";
          const timeText = x.time ? `<span class="stat-comment-time">${escapeHtml(x.time)}</span>` : "";
          return `<li class="stat-comment-item">
            <a class="stat-comment-link" href="${href}">
              <span class="stat-comment-author">${escapeHtml(x.author)}:</span>
              <span>${escapeHtml(x.content)}</span>
            </a>
            ${timeText}
          </li>`;
        })
        .join("");
      return `<ul class="stat-comment-list">${li}</ul>`;
    }

    function applyArticleBarRows(host, sumEl, withVals, recentComments) {
      const sum = withVals.reduce((acc, item) => acc + (Number(item.v) || 0), 0);
      if (sumEl) sumEl.textContent = String(sum);
      const byViews = renderRankList(withVals, "v");
      const recentCommentsHtml = renderRecentCommentsList(recentComments || []);
      host.innerHTML = `<div class="stat-rank-wrap">
        <section class="stat-rank-block">
          <h4 class="stat-rank-title">Top Reads</h4>
          ${byViews}
        </section>
        <section class="stat-rank-block">
          <h4 class="stat-rank-title">Recent Comments</h4>
          ${recentCommentsHtml}
        </section>
      </div>`;
    }

    async function loadPerArticleBarChart() {
      const host = document.getElementById("stat-article-views-bars");
      const sumEl = document.getElementById("stat-article-views-sum");
      if (!host) return;
      const rows = Array.isArray(perArticleViewRows) ? perArticleViewRows : [];
      if (rows.length === 0) {
        host.innerHTML = '<p class="stat-bar-load">No posts</p>';
        if (sumEl) sumEl.textContent = "0";
        return;
      }

      /** 启用 Supabase 后文章页不再 CountAPI /hit，路径聚合为 0 时历史计数仍只在 CountAPI；合并两者避免 Top Reads 全空 */
      let pathMap = null;
      if (articleViewsSource === "supabase") {
        const cfg =
          supabaseClientConfig &&
          typeof supabaseClientConfig === "object" &&
          typeof supabaseClientConfig.url === "string" &&
          typeof supabaseClientConfig.anonKey === "string"
            ? supabaseClientConfig
            : null;
        if (cfg) {
          const sk = String(cfg.anonKey || "").trim();
          if (sk.startsWith("sb_secret_")) {
            console.warn(
              "[stat] Supabase：当前为 Secret 公钥，无法用于网页；将回退 CountAPI。"
            );
          } else {
            try {
              const endpoint = String(cfg.url).replace(/\/+$/, "") +
                "/rest/v1/blog_visit_path_stats?select=page_path,views";
              const ctrl = new AbortController();
              const tid = setTimeout(() => ctrl.abort(), 12000);
              const res = await fetch(endpoint, {
                method: "GET",
                headers: {
                  apikey: cfg.anonKey,
                  Authorization: `Bearer ${cfg.anonKey}`,
                  Accept: "application/json",
                },
                signal: ctrl.signal,
              }).finally(() => clearTimeout(tid));
              if (res.ok) {
                const data = await res.json();
                pathMap = new Map();
                for (const r of data) {
                  const p = normalizeArticlePathForStats(String(r.page_path || ""));
                  const n = Number(r.views);
                  const add = Number.isFinite(n) ? n : 0;
                  pathMap.set(p, (pathMap.get(p) || 0) + add);
                }
              } else {
                console.warn("[stat] blog_visit_path_stats HTTP failed:", res.status);
              }
            } catch (e) {
              console.warn("[stat] blog_visit_path_stats failed, using CountAPI only", e);
            }
          }
        }
      }

      const CHUNK = 8;
      const withVals = [];
      for (let i = 0; i < rows.length; i += CHUNK) {
        const part = rows.slice(i, i + CHUNK);
        const vals = await Promise.all(
          part.map(async (r) => {
            const k2 = r.pathKey || normalizeArticlePathForStats(r.href);
            const fromDb = pathStatsViewsForArticle(pathMap, k2);
            const fromApi = await fetchCountValue(r.getUrl);
            return { ...r, v: fromDb + fromApi };
          })
        );
        withVals.push.apply(withVals, vals);
      }
      const recentComments = await fetchRecentComments(5);
      applyArticleBarRows(host, sumEl, withVals, recentComments);
    }

    function init() {
      try {
        updateStatistics();
      } catch (e) {
        console.error("updateStatistics() error:", e);
      }
      try {
        loadCountStats();
      } catch (e) {
        console.error("loadCountStats() error:", e);
      }
      try {
        loadPerArticleBarChart();
      } catch (e) {
        console.error("loadPerArticleBarChart() error:", e);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      setTimeout(init, 100);
    }

    setInterval(() => {
      updateStatistics();
      loadCountStats();
      loadPerArticleBarChart();
    }, 360000000);
  })();
</script>
