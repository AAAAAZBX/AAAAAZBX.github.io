---
const { title = "Admin Access" } = Astro.props as { title?: string };
const gateId = `admin-gate-${Math.random().toString(36).slice(2)}`;
---

<div class="admin-gate" data-admin-gate={gateId}>
  <div class="admin-gate__content" data-admin-content>
    <slot />
  </div>
  <div class="admin-gate__overlay" data-admin-overlay>
    <form class="admin-gate__panel" data-admin-form>
      <p class="admin-gate__eyebrow">Private Console</p>
      <h1>{title}</h1>
      <p class="admin-gate__desc">This route is locally locked. Enter the admin password to continue.</p>
      <input
        class="admin-gate__input"
        data-admin-password
        type="password"
        autocomplete="current-password"
        placeholder="Password"
      />
      <button class="admin-gate__button" type="submit">Unlock</button>
      <p class="admin-gate__status" data-admin-status></p>
      <p class="admin-gate__note">
        Static-site lock: useful for casual privacy, not a replacement for server-side authentication.
      </p>
    </form>
  </div>
</div>

<style is:global>
  .admin-gate__content {
    display: none;
  }
  .admin-gate.is-unlocked .admin-gate__content {
    display: block;
  }
  .admin-gate.is-unlocked .admin-gate__overlay {
    display: none;
  }
  .admin-gate__overlay {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
    background:
      radial-gradient(circle at 15% 12%, rgba(56, 189, 248, 0.18), transparent 34%),
      radial-gradient(circle at 82% 16%, rgba(244, 114, 182, 0.12), transparent 34%),
      linear-gradient(160deg, #0b1220 0%, #0f172a 48%, #101b30 100%);
    color: #e7eefb;
  }
  .admin-gate__panel {
    width: min(440px, 100%);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 22px;
    padding: 1.35rem;
    background: rgba(15, 23, 42, 0.74);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  }
  .admin-gate__eyebrow {
    margin: 0 0 0.35rem;
    color: #38bdf8;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 800;
  }
  .admin-gate__panel h1 {
    margin: 0;
    color: #f8fbff;
    font-size: 1.55rem;
  }
  .admin-gate__desc,
  .admin-gate__note,
  .admin-gate__status {
    color: #94a3b8;
    line-height: 1.55;
    font-size: 0.9rem;
  }
  .admin-gate__input {
    width: 100%;
    margin: 0.55rem 0 0.7rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 12px;
    padding: 0.72rem 0.8rem;
    background: rgba(2, 6, 23, 0.52);
    color: #e7eefb;
    font: inherit;
  }
  .admin-gate__button {
    width: 100%;
    border: 1px solid rgba(56, 189, 248, 0.35);
    border-radius: 12px;
    padding: 0.72rem 0.8rem;
    background: rgba(56, 189, 248, 0.18);
    color: #e0f2fe;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
  .admin-gate__button:hover {
    background: rgba(56, 189, 248, 0.26);
  }
  .admin-gate__status {
    min-height: 1.3em;
    margin: 0.7rem 0 0;
    color: #fca5a5;
  }
  .admin-gate__note {
    margin: 0.65rem 0 0;
    font-size: 0.78rem;
  }
</style>

<script define:vars={{ gateId }}>
  const ADMIN_HASH = "8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918";
  const SESSION_KEY = "bx_admin_unlocked_v1";

  async function sha256(input) {
    const bytes = new TextEncoder().encode(input);
    const digest = await crypto.subtle.digest("SHA-256", bytes);
    return [...new Uint8Array(digest)].map((x) => x.toString(16).padStart(2, "0")).join("");
  }

  function initAdminGate() {
    const root = document.querySelector(`[data-admin-gate="${gateId}"]`);
    if (!root) return;
    const form = root.querySelector("[data-admin-form]");
    const input = root.querySelector("[data-admin-password]");
    const status = root.querySelector("[data-admin-status]");
    const unlock = () => root.classList.add("is-unlocked");

    if (sessionStorage.getItem(SESSION_KEY) === "1") {
      unlock();
      return;
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const password = String(input?.value || "");
      const hash = await sha256(password);
      if (hash === ADMIN_HASH) {
        sessionStorage.setItem(SESSION_KEY, "1");
        unlock();
      } else if (status) {
        status.textContent = "Wrong password.";
      }
      if (input) input.value = "";
    });
  }

  initAdminGate();
</script>
