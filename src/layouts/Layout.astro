---
const {
  title = "Boxuan Zhang",
  isArticle = false,
  overlayNav = false,
  hideNav = false,
  noindex = false,
  /** 整页固定为暗色主题令牌（不随顶栏昼夜切换改变控制台样式） */
  lockPageDarkTheme = false,
} = Astro.props;
const logVisitorVisits = Boolean(
  import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);
const year = new Date().getFullYear();
/** 与 public 资源、Service Worker 注册一致（支持子路径部署） */
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- 防止夜间模式闪烁的早期脚本 -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('preferred-theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Favicon - 使用头像作为标签栏图标 -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="shortcut icon" type="image/png" href="/logo.png" />

    <!-- 与 lynx-li.github.io 文章页一致：Bootstrap 栅格 + GitHub Markdown 底座，再由 global 覆盖主题 -->
    <link
      rel="stylesheet"
      href="https://lib.baomitu.com/twitter-bootstrap/4.6.1/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://lib.baomitu.com/github-markdown-css/4.0.0/github-markdown.min.css"
    />
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- 顶图 / 头像：预连接 + 预加载，首屏略快；后续页由 Service Worker 复用缓存 -->
    <link rel="preload" as="image" href={`${baseUrl}site-profile.png`} fetchpriority="high" />
    <link rel="preload" as="image" href={`${baseUrl}logo.png`} />

    <!-- Fluid 顶栏图标（与 Lynx Li Hexo Fluid iconfont 一致） -->
    <link rel="stylesheet" href="https://at.alicdn.com/t/c/font_1749284_5i9bdhy70f8.css" />
    <link rel="stylesheet" href="https://at.alicdn.com/t/c/font_1736178_k526ubmyhba.css" />

    <!-- 内联样式：确保 Markdown 内部链接样式生效 -->
    <style>
      /* 确保侧边栏 sticky 定位生效 */
      main .sidebar,
      .page-container .sidebar,
      aside.sidebar {
        position: sticky !important;
        top: var(--sticky-top-offset) !important;
        align-self: flex-start !important;
      }

      /* Fluid 正文区：与 global.css 一致，!important 兜底 */
      #board .markdown-body h1,
      #board .markdown-body h2,
      #board .markdown-body h3,
      #board .markdown-body h4,
      #board .markdown-body h5,
      #board .markdown-body h6 {
        font-weight: 600 !important;
      }

      #board .markdown-body strong,
      #board .markdown-body b {
        font-weight: 600 !important;
      }

      #board .markdown-body a[href^="#"] {
        color: #8590a6 !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="#"]:link,
      #board .markdown-body a[href^="#"]:visited,
      #board .markdown-body a[href^="#"]:active {
        color: #8590a6 !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="#"]:hover {
        color: #8590a6 !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="#"].active,
      #board .markdown-body a[href^="#"].active:link,
      #board .markdown-body a[href^="#"].active:visited,
      #board .markdown-body a[href^="#"].active:hover,
      #board .markdown-body a[href^="#"].active:active {
        color: #1890ff !important;
        font-weight: 500 !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="http://"],
      #board .markdown-body a[href^="https://"],
      #board .markdown-body a[href^="//"],
      #board .markdown-body a[href^="/"]:not([href^="#"]) {
        color: #0969da !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="http://"]:link,
      #board .markdown-body a[href^="http://"]:visited,
      #board .markdown-body a[href^="https://"]:link,
      #board .markdown-body a[href^="https://"]:visited,
      #board .markdown-body a[href^="//"]:link,
      #board .markdown-body a[href^="//"]:visited,
      #board .markdown-body a[href^="/"]:not([href^="#"]):link,
      #board .markdown-body a[href^="/"]:not([href^="#"]):visited {
        color: #0969da !important;
        text-decoration: none !important;
      }
      #board .markdown-body a[href^="http://"]:hover,
      #board .markdown-body a[href^="https://"]:hover,
      #board .markdown-body a[href^="//"]:hover,
      #board .markdown-body a[href^="/"]:not([href^="#"]):hover {
        color: #0550ae !important;
        text-decoration: none !important;
      }
    </style>

    <!-- KaTeX 样式，用于渲染公式 -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.7/dist/katex.min.css"
    />

    <!-- Fira Code 字体 -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&display=swap"
    />
  </head>

  <body
    class:list={[overlayNav && "home-fluid-index", lockPageDarkTheme && "page-theme-lock-dark"]}
  >
    {
      !hideNav && (
        <header>
          <div class="nav">
            <div class="nav-inner">
            <div class="nav-left">
              <a href="/">B.X.Zhang</a>
            </div>
            <nav class="nav-links">
              <a href="/" class="nav-link-iconed">
                <i class="iconfont icon-home-fill" aria-hidden="true"></i>
                <span>Home</span>
              </a>
              <a href="/archives" class="nav-link-iconed">
                <i class="iconfont icon-archive-fill" aria-hidden="true"></i>
                <span>Archives</span>
              </a>
              <a href="/categories" class="nav-link-iconed">
                <i class="iconfont icon-category-fill" aria-hidden="true"></i>
                <span>Categories</span>
              </a>
              {/** Statistics 页不放入导航，仅自己记 URL `/statistics` 访问 */}
              <a href="/about" class="nav-link-iconed">
                <i class="iconfont icon-user-fill" aria-hidden="true"></i>
                <span>About</span>
              </a>
              <a href="/search" class="nav-search-link" title="Search" aria-label="Search">
                <i class="iconfont icon-search" aria-hidden="true"></i>
              </a>
              <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
                <!-- 太阳图标（亮色模式） -->
                <svg class="theme-icon theme-icon-light" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5"></circle>
                  <line x1="12" y1="1" x2="12" y2="3"></line>
                  <line x1="12" y1="21" x2="12" y2="23"></line>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                  <line x1="1" y1="12" x2="3" y2="12"></line>
                  <line x1="21" y1="12" x2="23" y2="12"></line>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
                <!-- 月亮图标（暗色模式） -->
                <svg class="theme-icon theme-icon-dark" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
              </button>
            </nav>
            </div>
          </div>
        </header>
      )
    }

    {
      lockPageDarkTheme ? (
        <div class="dark page-theme-lock-wrap">
          <slot />
          <footer>© {year} Boxuan Zhang</footer>
        </div>
      ) : (
        <>
          <slot />
          <footer>© {year} Boxuan Zhang</footer>
        </>
      )
    }

    {
      logVisitorVisits && (
        <script>
          import { runVisitLog } from "../scripts/visit-logger.ts";
          void runVisitLog({ siteBasePath: import.meta.env.BASE_URL });
        </script>
      )
    }

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // 夜间模式切换功能
        (function() {
          // 从 localStorage 读取主题偏好，默认为亮色
          const savedTheme = localStorage.getItem('preferred-theme') || 'light';
          
          function setTheme(theme) {
            // 保存到 localStorage
            localStorage.setItem('preferred-theme', theme);
            
            // 切换 body 的 dark 类
            if (theme === 'dark') {
              document.documentElement.classList.add('dark');
              document.body.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
              document.body.classList.remove('dark');
            }
            
            // 切换图标显示
            const lightIcon = document.querySelector('.theme-icon-light');
            const darkIcon = document.querySelector('.theme-icon-dark');
            if (lightIcon && darkIcon) {
              if (theme === 'dark') {
                lightIcon.style.display = 'none';
                darkIcon.style.display = '';
              } else {
                lightIcon.style.display = '';
                darkIcon.style.display = 'none';
              }
            }
          }
          
          // 初始化主题（在页面加载前执行，避免闪烁）
          setTheme(savedTheme);
          
          // 主题切换按钮点击事件
          const themeToggle = document.getElementById('theme-toggle');
          if (themeToggle) {
            themeToggle.addEventListener('click', () => {
              const currentTheme = localStorage.getItem('preferred-theme') || 'light';
              const newTheme = currentTheme === 'light' ? 'dark' : 'light';
              setTheme(newTheme);
            });
            
            // 阻止空格键触发按钮点击（避免与小恐龙游戏冲突）
            themeToggle.addEventListener('keydown', (e) => {
              if (e.key === ' ' || e.keyCode === 32) {
                e.preventDefault();
                e.stopPropagation();
              }
            });
          }
        })();

        // 仅首页首屏：滑到最上时顶栏更透明，下滚后渐变为实色（不改动条高与链接间距）
        (function homeNavTransparency() {
          if (!document.body.classList.contains("home-fluid-index")) return;
          const header = document.querySelector("header");
          if (!header) return;
          let ticking = false;
          function update() {
            const st = window.pageYOffset || document.documentElement.scrollTop;
            if (st > 50) header.classList.add("scrolled");
            else header.classList.remove("scrolled");
            ticking = false;
          }
          function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(update);
          }
          window.addEventListener("scroll", onScroll, { passive: true });
          update();
        })();
        
        // 平滑滚动
        document.documentElement.style.scrollBehavior = 'smooth';

        // 移除当前页面链接的高亮（用户要求：只有悬停时才显示蓝色）
        // 不再添加 active 类和 aria-current 属性

        // 代码块复制按钮 + 超长代码折叠
        const COLLAPSE_LINES = 20;
        document.querySelectorAll("pre.astro-code").forEach((pre) => {
          if (pre.querySelector("button.code-copy")) return;

          const btn = document.createElement("button");
          btn.className = "code-copy";
          btn.textContent = "Copy";

          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code");
            if (!code) return;
            const text = code.innerText;

            try {
              await navigator.clipboard.writeText(text);
              const old = btn.textContent;
              btn.textContent = "Copied";
              setTimeout(() => (btn.textContent = old), 1500);
            } catch (e) {
              console.error(e);
            }
          });

          pre.appendChild(btn);

          const code = pre.querySelector("code");
          if (!code || pre.dataset.foldInit === "1") return;
          pre.dataset.foldInit = "1";

          const raw = (code.textContent || "").replace(/\n$/, "");
          const lineCount = raw ? raw.split("\n").length : 0;
          if (lineCount <= COLLAPSE_LINES) return;

          const codeStyle = window.getComputedStyle(code);
          const preStyle = window.getComputedStyle(pre);
          const lineHeight = parseFloat(codeStyle.lineHeight) || 20;
          const padTop = parseFloat(preStyle.paddingTop) || 0;
          const padBottom = parseFloat(preStyle.paddingBottom) || 0;
          const collapsedHeight = Math.ceil(lineHeight * COLLAPSE_LINES + padTop + padBottom + 2);

          const wrapper = document.createElement("div");
          wrapper.className = "code-collapse-wrap";
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const toggle = document.createElement("button");
          toggle.className = "code-toggle";
          toggle.type = "button";
          toggle.textContent = "Expand";

          const setCollapsed = (collapsed) => {
            pre.classList.toggle("is-collapsed", collapsed);
            pre.style.maxHeight = collapsed ? `${collapsedHeight}px` : "none";
            wrapper.classList.toggle("is-expanded", !collapsed);
            toggle.textContent = collapsed ? "Expand" : "Collapse";
            toggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
          };

          toggle.addEventListener("click", () => {
            const collapsed = pre.classList.contains("is-collapsed");
            setCollapsed(!collapsed);
          });

          pre.classList.add("code-collapsible");
          wrapper.appendChild(toggle);
          setCollapsed(true);
        });

        // Markdown 内部目录链接的高亮功能
        const article = document.querySelector("#board .markdown-body");
        if (!article) return;

        // 获取所有锚点链接（href 以 # 开头的链接）
        const anchorLinks = article.querySelectorAll('a[href^="#"]');
        if (anchorLinks.length === 0) return;

        // 获取所有标题元素
        const headings = article.querySelectorAll("h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]");
        if (headings.length === 0) return;

        // 更新激活链接的函数
        const updateActiveLink = () => {
          const hash = window.location.hash;
          anchorLinks.forEach((link) => {
            link.classList.remove("active");
            if (hash && link.getAttribute("href") === hash) {
              link.classList.add("active");
            }
          });
        };

        // 使用 Intersection Observer 来检测当前可见的标题
        const observerOptions = {
          rootMargin: "-20% 0px -70% 0px",
          threshold: 0,
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              if (id) {
                // 更新 URL（不创建历史记录）
                const url = window.location.pathname + `#${id}`;
                window.history.replaceState(null, "", url);
                
                // 更新激活的链接
                anchorLinks.forEach((link) => {
                  link.classList.remove("active");
                  if (link.getAttribute("href") === `#${id}`) {
                    link.classList.add("active");
                  }
                });
              }
            }
          });
        }, observerOptions);

        // 观察所有标题
        headings.forEach((heading) => observer.observe(heading));

        // 点击链接时的处理
        anchorLinks.forEach((link) => {
          link.addEventListener("click", (e) => {
            e.preventDefault();
            const targetId = link.getAttribute("href")?.substring(1);
            const target = document.getElementById(targetId || "");
            if (target) {
              target.scrollIntoView({ behavior: "smooth", block: "start" });
              // 使用 replaceState 避免在历史记录中留下锚点
              const url = window.location.pathname + (targetId ? `#${targetId}` : "");
              window.history.replaceState(null, "", url);
              // 更新激活状态
              updateActiveLink();
            }
          });
        });

        // 页面加载时，如果有锚点，高亮对应的链接
        updateActiveLink();

        // 监听浏览器前进/后退
        window.addEventListener("popstate", () => {
          updateActiveLink();
          const hash = window.location.hash;
          if (hash) {
            const target = document.getElementById(hash.substring(1));
            if (target) {
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
          }
        });
      });
    </script>

    <!-- Client-side visibility filter: reads hidden IDs from Supabase and hides posts -->
    <script is:inline define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
      (function () {
        var url = supabaseUrl;
        var key = supabaseAnonKey;
        if (!url || !key) return;
        try {
          fetch(url + "/rest/v1/content_visibility?select=hidden_posts&id=eq.1", {
            headers: { apikey: key, Authorization: "Bearer " + key }
          })
            .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
            .then(function (rows) {
              var hidden = (Array.isArray(rows) && rows[0] && Array.isArray(rows[0].hidden_posts))
                ? rows[0].hidden_posts.map(function (s) { return String(s).trim().toLowerCase(); })
                : [];
              if (hidden.length) {
                hidden.forEach(function (id) {
                  var els = document.querySelectorAll('[data-post-id="' + id + '"]');
                  for (var i = 0; i < els.length; i++) {
                    els[i].style.display = "none";
                  }
                });
              }

              // Recalculate homepage pagination
              var allItems = document.querySelectorAll('.home-post-item');
              var visible = 0;
              for (var i = 0; i < allItems.length; i++) {
                if (allItems[i].style.display !== 'none') visible++;
              }
              var pagination = document.querySelector('.home-pagination');
              if (pagination) {
                pagination.style.display = visible > 10 ? '' : 'none';
              }

              // Hide empty category sections
              var sections = document.querySelectorAll('.cat-section, .fluid-category-section');
              for (var i = 0; i < sections.length; i++) {
                var links = sections[i].querySelectorAll('[data-post-id]');
                var allHidden = links.length > 0;
                for (var j = 0; j < links.length; j++) {
                  if (links[j].style.display !== 'none') { allHidden = false; break; }
                }
                if (allHidden) sections[i].style.display = 'none';
              }
            })
            .catch(function () { /* Supabase unreachable, skip client-side filter */ });
        } catch (_) {}
      })();
    </script>
    <script is:inline define:vars={{ baseUrl }}>
      (function () {
        if (!("serviceWorker" in navigator)) return;
        var scope = baseUrl || "/";
        if (scope.slice(-1) !== "/") scope += "/";
        navigator.serviceWorker.register(scope + "sw.js", { scope: scope }).catch(function () {});
      })();
    </script>
    <script>
      import { runSitewideCountHit } from "../scripts/sitewide-count-hit.ts";
      import { countapiHitUrl, getCountapiNamespace, COUNTAPI_KEYS } from "../lib/site-stats";

      runSitewideCountHit({
        siteBasePath: import.meta.env.BASE_URL,
        hitUrl: countapiHitUrl(getCountapiNamespace(), COUNTAPI_KEYS.sitePageViews),
      });
    </script>
  </body>
</html>